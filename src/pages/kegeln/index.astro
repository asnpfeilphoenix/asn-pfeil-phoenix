---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactsBar from '../../components/ContactsBar.astro';
import { getCollection } from 'astro:content';
import Papa from 'papaparse';
import fs from 'node:fs';
import path from 'node:path';

const csvText = fs.readFileSync(
  path.join(process.cwd(), 'public/data/kegeln-kontakte.csv'), 'utf-8'
).replace(/^\uFEFF/, '');
const { data: rows } = Papa.parse(csvText, { delimiter: ';', header: true, skipEmptyLines: true });
const contacts = (rows as any[]).map(r => ({
  rolle:   (r['Rolle']   || '').trim(),
  name:    (r['Name']    || '').trim(),
  telefon: (r['Telefon'] || '').trim(),
  email:   (r['Email']   || '').trim(),
  foto:    (r['Foto']    || '').trim(),
}));

const posts = (await getCollection('news', ({ data }) => !data.draft && data.sport === 'kegeln'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);
---

<BaseLayout title="Kegeln" description="Die Kegelabteilung des ASN Pfeil Phönix e.V.">

  <header class="dept-header">
    <div class="container">
      <span class="section-eyebrow">Abteilung</span>
      <h1>Kegeln</h1>
      <p class="dept-sub">Geselliges Kegeln mit Mannschaftsbetrieb und Turnieren.</p>
    </div>
  </header>

  <section class="section">
    <div class="container grid-2">
      <div>
        <h2>Über die Abteilung</h2>
        <p style="color:var(--mid);line-height:1.75;margin-top:1rem">Die Kegelabteilung des ASN Pfeil Phönix ist eine feste Größe im Vereinsleben. Wir spielen regelmäßig im Mannschaftsbetrieb und veranstalten vereinseigene Turniere. Dabei steht neben dem sportlichen auch der gesellige Aspekt stets im Vordergrund.</p>
      </div>
      <div>
        <h2>Mitmachen</h2>
        <p style="color:var(--mid);line-height:1.75;margin-top:1rem">Interessierte sind herzlich willkommen — meldet euch einfach beim Vorstand oder schreibt an <a href="mailto:info@asn-pfeil-phoenix.de" style="color:var(--navy)">info@asn-pfeil-phoenix.de</a>.</p>
        <a href="/verein#mitglied" class="btn btn--primary" style="margin-top:1.25rem">Mitglied werden →</a>
      </div>
    </div>
  </section>

  <ContactsBar contacts={contacts} eyebrow="Kegelabteilung" title="Ansprechpartner" />

  {posts.length > 0 && (
    <section class="section">
      <div class="container">
        <p class="section-eyebrow">Aktuelles</p>
        <h2>Kegeln-News</h2>
        <div class="grid-3">
          {posts.map(post => (
            <a href={`/news/${post.slug}`} class="card">
              <div class="card__body">
                <div class="card__meta">
                  <span class="tag tag--kegeln">Kegeln</span>
                  <time>{post.data.date.toLocaleDateString('de-DE')}</time>
                </div>
                <h3 class="card__title">{post.data.title}</h3>
                <p class="card__excerpt">{post.data.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style>
.dept-header { padding: 4rem 0 3rem; background: var(--navy-dark); border-bottom: 4px solid var(--navy-mid); }
.dept-header h1 { color: var(--white); font-size: clamp(2.5rem, 8vw, 6rem); }
.dept-header .section-eyebrow { color: rgba(255,255,255,.5); }
.dept-header .section-eyebrow::before { background: var(--orange); }
.dept-sub { color: rgba(255,255,255,.55); margin-top: .75rem; }
</style>
