---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('news', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

function formatDate(date: Date) {
  return date.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

const depts = [
  { name: 'Fußball',  href: '/fussball', cls: 'dc-f', icon: '⚽', label: 'Abteilung' },
  { name: 'Tennis',   href: '/tennis',   cls: 'dc-t', icon: '🎾', label: 'Abteilung' },
  { name: 'Kegeln',   href: '/kegeln',   cls: 'dc-k', icon: '🎳', label: 'Abteilung' },
  { name: 'Dart',     href: '/dart',     cls: 'dc-d', icon: '🎯', label: 'Abteilung · Neu' },
  { name: 'Radsport', href: 'https://www.pfeil-phoenix-radsport.com', cls: 'dc-r', icon: '🚴', label: 'Abteilung', external: true },
];
---

<BaseLayout title="ASN Pfeil Phönix" description="Ein Verein für Alle — Fußball, Tennis, Kegeln, Dart und Radsport in Nürnberg seit 1905.">

  <!-- ===== HERO CAROUSEL ===== -->
  <section class="hero" aria-label="Herzlich Willkommen">
    <div class="carousel-track" id="carousel-track">

      <div class="slide slide--1">
        <div class="slide__fade"></div>
        <div class="container slide__body">
          <span class="slide__tag">Allgemeiner Sportverein Nürnberg · seit 1905</span>
          <h1 class="slide__title">Ein Verein<br>für <em>Alle</em></h1>
          <p class="slide__text">Wir sind ein traditionsreicher Sportverein, der ein bisschen anders tickt. Seit 1905 in Ziegelstein — mit Fußball, Tennis, Kegeln, Dart und Radsport unter einem Dach.</p>
          <div class="slide__btns">
            <a href="/verein" class="btn btn--primary">Mehr über uns</a>
            <a href="/verein#mitglied" class="btn btn--ghost-w">Mitglied werden</a>
          </div>
        </div>
      </div>

      <div class="slide slide--2">
        <div class="slide__fade"></div>
        <div class="container slide__body">
          <span class="slide__tag">Fußball · Herren, Mädels &amp; Jugend</span>
          <h1 class="slide__title">Die<br><em>Assen</em></h1>
          <p class="slide__text">Leidenschaftlicher Fußball auf und neben dem Platz. Komm zum Probetraining an der Marienbergstraße.</p>
          <div class="slide__btns">
            <a href="/fussball" class="btn btn--primary">Zur Fußballabteilung</a>
          </div>
        </div>
      </div>

      <div class="slide slide--3">
        <div class="slide__fade"></div>
        <div class="container slide__body">
          <span class="slide__tag">Radsport · Gemeinschaft · Ziegelstein</span>
          <h1 class="slide__title">Mehr als<br>nur <em>Sport</em></h1>
          <p class="slide__text">Vereinsfeste, Turniere, gemeinsame Abende — bei den Assen ist Sport nur der Anfang. Hier wächst echte Gemeinschaft.</p>
          <div class="slide__btns">
            <a href="/verein#mitglied" class="btn btn--primary">Jetzt Mitglied werden</a>
            <a href="/news" class="btn btn--ghost-w">Aktuelle News</a>
          </div>
        </div>
      </div>

    </div>

    <button class="carousel-prev" id="carousel-prev" aria-label="Zurück">←</button>
    <button class="carousel-next" id="carousel-next" aria-label="Weiter">→</button>
    <div class="carousel-dots" role="tablist">
      <button class="carousel-dot is-active" aria-label="Folie 1"></button>
      <button class="carousel-dot" aria-label="Folie 2"></button>
      <button class="carousel-dot" aria-label="Folie 3"></button>
    </div>
  </section>

  <!-- ===== NEWS ===== -->
  <section class="section section--off">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="section-eyebrow">Aktuelles</p>
          <h2>Neueste Nachrichten</h2>
        </div>
        <a href="/news" class="btn btn--ghost" style="font-size:.8rem">Alle News →</a>
      </div>

      {latestPosts.length > 0 ? (
        <div class="news-layout">
          <a href={`/news/${latestPosts[0].slug}`} class="news-feat">
            {latestPosts[0].data.image ? (
              <img class="news-feat__img" src={latestPosts[0].data.image} alt={latestPosts[0].data.title} />
            ) : (
              <div class="news-feat__img news-feat__img--ph"><span>{latestPosts[0].data.sport}</span></div>
            )}
            <div class="news-feat__body">
              <span class={`tag tag--${latestPosts[0].data.sport}`}>{latestPosts[0].data.sport}</span>
              <h3 class="news-feat__title">{latestPosts[0].data.title}</h3>
              <p class="news-feat__excerpt">{latestPosts[0].data.excerpt}</p>
              <div class="news-feat__meta">
                <span>{formatDate(latestPosts[0].data.date)}</span>
                <span class="news-feat__rm">Weiterlesen →</span>
              </div>
            </div>
          </a>

          <div class="news-list">
            {latestPosts.slice(1).map(post => (
              <a href={`/news/${post.slug}`} class="news-item">
                <div class="news-item__thumb">
                  {post.data.sport === 'fussball' ? '⚽' : post.data.sport === 'tennis' ? '🎾' : post.data.sport === 'kegeln' ? '🎳' : post.data.sport === 'dart' ? '🎯' : post.data.sport === 'radsport' ? '🚴' : '📋'}
                </div>
                <div class="news-item__body">
                  <span class={`tag tag--${post.data.sport}`}>{post.data.sport}</span>
                  <div class="news-item__title">{post.data.title}</div>
                  <span class="news-item__date">{formatDate(post.data.date)}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <p style="color:var(--muted);font-style:italic">Noch keine Beiträge vorhanden.</p>
      )}
    </div>
  </section>

  <!-- ===== FÜR ASSEN-FANS ===== -->
  <section class="section">
    <div class="container">
      <p class="section-eyebrow">Für Assen-Fans</p>
      <h2>Shop &amp; Unterstützung</h2>
      <div class="fans-grid">

        <!-- Fan Webshop -->
        <a href="https://asnpfeilphoenix.myteamshop.de/" target="_blank" rel="noopener" class="fans-card">
          <div class="fans-card__img">
            <img src="/images/asn-shop-banner.png" alt="ASN Pfeil Phönix Onlineshop" />
          </div>
          <div class="fans-card__body">
            <h3 class="fans-card__title">Fan-Webshop</h3>
            <p class="fans-card__text">Merch und mehr — unterstütze den Verein.</p>
            <span class="fans-card__cta">Zum Shop →</span>
          </div>
        </a>

        <!-- Jako Kit Shop -->
        <a href="https://team.jako.com/de-de/team/asn_pfeil_phoenix/" target="_blank" rel="noopener" class="fans-card">
          <div class="fans-card__img fans-card__img--white">
            <img src="/images/guenthers-sport-shop.png" alt="Günther's Sport-Shop Nürnberg" />
          </div>
          <div class="fans-card__body">
            <h3 class="fans-card__title">Jako Teamshop</h3>
            <p class="fans-card__text">Offizielle Vereinsausrüstung von Jako — für Spieler und Fans.</p>
            <span class="fans-card__cta">Zum Teamshop →</span>
          </div>
        </a>

        <!-- Klubkasse -->
        <a href="https://www.klubkasse.de/klub-page.html?club_id=1934" target="_blank" rel="noopener" class="fans-card">
          <div class="fans-card__img fans-card__img--navy">
            <img src="https://mzm.klubkasse.de/banner.php?id=364&club_id=1934" alt="Klubkasse.de" loading="lazy" />
          </div>
          <div class="fans-card__body">
            <h3 class="fans-card__title">Klubkasse</h3>
            <p class="fans-card__text">Unterstütze den Verein direkt — einfach und unkompliziert.</p>
            <span class="fans-card__cta">Zur Klubkasse →</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ===== DEPARTMENTS ===== -->
  <section class="section">
    <div class="container">
      <p class="section-eyebrow">Unsere Abteilungen</p>
      <h2>Sport für jeden Geschmack</h2>
      <div class="dept-grid">
        {depts.map(dept => (
          <a
            href={dept.href}
            class={`dept-card ${dept.cls}`}
            {...(dept.external ? { target: '_blank', rel: 'noopener' } : {})}
          >
            <div class="dept-card__photo"></div>
            <div class="dept-card__ov"></div>
            <span class="dept-card__icon">{dept.icon}</span>
            {dept.external && <span class="dept-card__ext">↗ extern</span>}
            <div class="dept-card__body">
              <span class="dept-card__label">{dept.label}</span>
              <div class="dept-card__name">{dept.name}</div>
              <span class="dept-card__cta">Mehr erfahren →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== JOIN ===== -->
  <section class="section section--navy">
    <div class="container join-inner">
      <div>
        <span class="join-kicker">Die Assen · Nürnberg · seit 1905</span>
        <h2 class="join-title">Werde Teil der Familie.</h2>
        <p class="join-sub">Offen für alle — egal ob 6 oder 86, Anfänger oder Profi.</p>
      </div>
      <div style="display:flex;gap:.75rem;flex-wrap:wrap">
        <a href="/verein#mitglied" class="btn btn--white">Mitglied werden</a>
        <a href="/verein#kontakt" class="btn btn--ghost-w">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const track = document.getElementById('carousel-track')!;
  const dots = document.querySelectorAll<HTMLElement>('.carousel-dot');
  let cur = 0;
  const total = 3;
  let timer: ReturnType<typeof setInterval>;

  function go(n: number) {
    cur = (n + total) % total;
    track.style.transform = `translateX(-${cur * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('is-active', i === cur));
  }
  function reset() { clearInterval(timer); timer = setInterval(() => go(cur + 1), 5500); }

  document.getElementById('carousel-next')!.addEventListener('click', () => { go(cur + 1); reset(); });
  document.getElementById('carousel-prev')!.addEventListener('click', () => { go(cur - 1); reset(); });
  dots.forEach((d, i) => d.addEventListener('click', () => { go(i); reset(); }));
  reset();
</script>

<style>
/* ---- Hero ---- */
.hero {
  position: relative; overflow: hidden;
  height: clamp(500px, 88vh, 820px);
}
.carousel-track {
  display: flex; height: 100%;
  transition: transform 0.75s cubic-bezier(.4,0,.2,1);
}
.slide {
  min-width: 100%; height: 100%;
  position: relative; display: flex; align-items: flex-end;
  background-size: cover; background-position: center;
}
.slide--1 { background-image: url('/images/asn-grounds-photo.png'); background-position: center 30%; }
.slide--2 { background-image: url('/images/asn-team-photo.png'); background-position: center top; }
.slide--3 { background-image: url('/images/asn-cycling-photo.png'); background-position: center; }

.slide__fade {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.8) 0%, rgba(0,0,0,.45) 35%, rgba(0,0,0,.15) 65%, transparent 100%);
}
.slide__body {
  position: relative; z-index: 1;
  padding-bottom: clamp(3rem, 6vw, 5.5rem);
  padding-top: 2rem;
  max-width: 820px;
}
.slide__tag {
  display: inline-block; font-size: .68rem; font-weight: 700;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--orange); background: rgba(232,120,10,.12);
  border: 1px solid rgba(232,120,10,.3);
  padding: .3em .85em; border-radius: 99px; margin-bottom: 1rem;
}
.slide__title {
  font-family: var(--fd);
  font-size: clamp(3rem, 9vw, 7.5rem);
  color: var(--white); line-height: .9;
  letter-spacing: .01em; margin-bottom: 1.25rem;
}
.slide__title em { color: var(--orange); font-style: normal; }
.slide__text {
  font-size: clamp(.9rem, 1.5vw, 1.05rem);
  color: rgba(255,255,255,.8); line-height: 1.75;
  max-width: 54ch; margin-bottom: 1.75rem;
}
.slide__btns { display: flex; gap: .75rem; flex-wrap: wrap; }

.carousel-prev, .carousel-next {
  position: absolute; top: 50%; transform: translateY(-50%); z-index: 10;
  width: 50px; height: 50px; border-radius: 50%; cursor: pointer;
  background: rgba(255,255,255,.12); backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,.2); color: white; font-size: 1.1rem;
  display: flex; align-items: center; justify-content: center;
  transition: background .2s; padding: 0;
}
.carousel-prev { left: 1.5rem; }
.carousel-next { right: 1.5rem; }
.carousel-prev:hover, .carousel-next:hover { background: rgba(255,255,255,.25); }

.carousel-dots {
  position: absolute; bottom: 1.75rem; left: 50%;
  transform: translateX(-50%); display: flex; gap: .5rem; z-index: 10;
}
.carousel-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: rgba(255,255,255,.35); border: none; cursor: pointer; padding: 0;
  transition: background .2s, transform .2s;
}
.carousel-dot.is-active { background: var(--white); transform: scale(1.3); }

/* ---- News ---- */
.news-layout { display: grid; grid-template-columns: 5fr 3fr; gap: 1.5rem; }
@media (max-width: 800px) { .news-layout { grid-template-columns: 1fr; } }

.news-feat {
  background: var(--white); border-radius: var(--radius-lg);
  border: 1px solid var(--border); overflow: hidden;
  display: flex; flex-direction: column;
  transition: box-shadow .2s, transform .2s;
}
.news-feat:hover { box-shadow: 0 12px 40px rgba(15,41,114,.1); transform: translateY(-3px); }
.news-feat__img {
  aspect-ratio: 16/8; object-fit: cover; width: 100%; display: block;
}
.news-feat__img--ph {
  aspect-ratio: 16/8; background: var(--navy-pale);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--fd); font-size: 4rem;
  color: rgba(15,41,114,.15); letter-spacing: .1em; text-transform: uppercase;
}
.news-feat__body { padding: 1.5rem 1.75rem 1.75rem; flex: 1; display: flex; flex-direction: column; }
.news-feat__title { font-family: var(--fd); font-size: 1.7rem; line-height: 1.05; margin-bottom: .6rem; }
.news-feat__excerpt { font-size: .9rem; color: var(--mid); line-height: 1.7; }
.news-feat__meta {
  margin-top: auto; padding-top: 1.25rem;
  display: flex; justify-content: space-between; align-items: center;
  font-size: .78rem; color: var(--muted);
  border-top: 1px solid var(--border);
}
.news-feat__rm { color: var(--navy); font-weight: 600; font-size: .78rem; }

.news-list { display: flex; flex-direction: column; }
.news-item {
  display: flex; gap: 1rem; padding: .9rem 1rem;
  background: var(--white); border-bottom: 1px solid var(--border);
  transition: background .15s;
}
.news-item:first-child { border-radius: var(--radius-lg) var(--radius-lg) 0 0; }
.news-item:last-child  { border-radius: 0 0 var(--radius-lg) var(--radius-lg); border-bottom: none; }
.news-item:hover { background: var(--navy-tint); }
.news-item__thumb {
  width: 50px; height: 50px; border-radius: 8px;
  background: var(--navy-pale); flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 1.3rem;
}
.news-item__body { flex: 1; min-width: 0; }
.news-item__title {
  font-family: var(--fd); font-size: .95rem; line-height: 1.15; color: var(--ink);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.news-item__date { font-size: .68rem; color: var(--muted); margin-top: .15rem; display: block; }

/* ---- Fans section ---- */
.fans-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem; margin-top: 2rem;
}
@media (max-width: 800px) { .fans-grid { grid-template-columns: 1fr; } }

.fans-card {
  background: var(--white); border-radius: var(--radius-lg);
  border: 1px solid var(--border); overflow: hidden;
  display: flex; flex-direction: column;
  transition: box-shadow .2s, transform .2s;
}
.fans-card:hover { box-shadow: 0 12px 40px rgba(15,41,114,.1); transform: translateY(-3px); }
.fans-card__img {
  aspect-ratio: 16/7; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  background: var(--navy-pale);
}
.fans-card__img img { width: 100%; height: 100%; object-fit: cover; }
.fans-card__img--white { background: var(--white); padding: 0.5rem; }
.fans-card__img--white img { object-fit: contain; }
.fans-card__img--navy { background: var(--navy); padding: 0.5rem; }
.fans-card__img--navy img { object-fit: contain; width: 100%; height: 100%; }
.fans-card__body { padding: 1.25rem 1.5rem 1.5rem; flex: 1; display: flex; flex-direction: column; }
.fans-card__title { font-family: var(--fd); font-size: 1.3rem; margin-bottom: .4rem; }
.fans-card__text { font-size: .88rem; color: var(--mid); line-height: 1.6; flex: 1; }
.fans-card__cta { margin-top: 1rem; font-size: .82rem; font-weight: 600; color: var(--navy); }
.fans-card:hover .fans-card__cta { text-decoration: underline; }

/* ---- Departments ---- */
.dept-grid {
  display: grid; grid-template-columns: repeat(5, 1fr);
  gap: 1.25rem; margin-top: 2rem;
}
@media (max-width: 1100px) { .dept-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 640px)  { .dept-grid { grid-template-columns: repeat(2, 1fr); } }

.dept-card {
  border-radius: 14px; overflow: hidden; position: relative;
  aspect-ratio: 3/4; display: flex; flex-direction: column;
  justify-content: flex-end; cursor: pointer; transition: transform .25s;
}
.dept-card:hover { transform: scale(1.03); }
.dept-card__photo {
  position: absolute; inset: 0;
  background-size: cover; background-position: center;
  transition: transform .4s;
}
.dept-card:hover .dept-card__photo { transform: scale(1.07); }

.dc-f .dept-card__photo { background-image: url('/images/asn-team-photo.png'); background-position: center top; }
.dc-t .dept-card__photo { background-image: url('https://images.pexels.com/photos/1432039/pexels-photo-1432039.jpeg?auto=compress&w=600'); background-color: var(--navy); }
.dc-k .dept-card__photo { background-image: url('https://upload.wikimedia.org/wikipedia/commons/8/8e/Kegeln-Kugel.jpg'); background-color: var(--navy-dark); }
.dc-d .dept-card__photo { background-image: url('https://images.pexels.com/photos/10680031/pexels-photo-10680031.jpeg?auto=compress&w=600'); background-color: #2d0a47; }
.dc-r .dept-card__photo { background-image: url('/images/asn-cycling-photo.png'); background-position: center; }

.dept-card__ov {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.72) 0%, rgba(0,0,0,.2) 55%, transparent 100%);
}
.dept-card__icon { position: absolute; top: 1rem; right: 1rem; font-size: 2.2rem; opacity: .2; }
.dept-card__ext {
  position: absolute; top: .85rem; left: .85rem;
  font-size: .6rem; font-weight: 700; letter-spacing: .08em;
  color: rgba(255,255,255,.5); background: rgba(255,255,255,.1);
  border-radius: 99px; padding: .2em .55em;
}
.dept-card__body { position: relative; z-index: 1; padding: 1.1rem 1.25rem; }
.dept-card__label { font-size: .58rem; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; color: rgba(255,255,255,.5); display: block; margin-bottom: .25rem; }
.dept-card__name { font-family: var(--fd); font-size: clamp(1.4rem, 2.5vw, 1.9rem); color: var(--white); line-height: 1; }
.dept-card__cta { font-size: .7rem; font-weight: 600; color: rgba(255,255,255,.55); margin-top: .4rem; display: block; transition: color .2s; }
.dept-card:hover .dept-card__cta { color: var(--white); }

/* ---- Join ---- */
.join-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
.join-kicker { font-size: .72rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: rgba(255,255,255,.45); display: block; margin-bottom: .5rem; }
.join-title { font-family: var(--fd); font-size: clamp(2rem, 5vw, 3.5rem); color: var(--white); line-height: 1; }
.join-sub { color: rgba(255,255,255,.55); font-size: .95rem; margin-top: .5rem; }
</style>