---
// src/pages/sommer-camp.astro
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="Sommer-Fußballcamp 2026" description="Anmeldung zum Sommer-Fußballcamp 2026 des ASN Pfeil Phönix e.V.">

  <!-- Hero -->
  <section class="camp-hero">
    <div class="container">
      <p class="section-eyebrow">Fußballabteilung</p>
      <h1>Sommer-Fußball<em>camp</em> 2026</h1>
      <div class="camp-meta">
        <span class="camp-meta-item">📅 3. – 7. August 2026</span>
        <span class="camp-meta-item">🕘 9 – 12 Uhr täglich</span>
        <span class="camp-meta-item">💶 99 € inkl. Trikot</span>
        <span class="camp-meta-item">📍 ASN Pfeil Phönix, Nürnberg</span>
      </div>
    </div>
  </section>

  <!-- Info section -->
  <section class="section">
    <div class="container camp-container">

      <!-- Alert banner -->
      <div class="camp-alert">
        <span class="camp-alert-icon">⚽</span>
        <div>
          <strong>Anmeldeschluss: 10. Juni 2026</strong> — damit die Trikots rechtzeitig geliefert werden können. Noch <span id="days-left"></span> — jetzt anmelden!
        </div>
      </div>

      <!-- Info grid -->
      <div class="camp-info-grid">
        <div class="camp-info-card">
          
          <h3>Ziel & Inhalt</h3>
          <p>In kleinen Gruppen von 8–10 Spieler*innen arbeiten wir intensiv an der Verbesserung technischer und taktischer Fähigkeiten — und haben dabei jede Menge Spaß.</p>
        </div>
        <div class="camp-info-card">
          
          <h3>Zielgruppe</h3>
          <p>Offen für alle Großfeldspieler*innen der <strong>A- bis D-Jugend</strong>. Wir haben <strong>40 Plätze</strong> — also schnell sein!</p>
        </div>
        <div class="camp-info-card">
          
          <h3>Abschluss-BBQ</h3>
          <p>Am letzten Tag (7. August 2026) organisieren wir ein großes <strong>BBQ für alle</strong> Teilnehmer*innen — der perfekte Abschluss einer tollen Woche.</p>
        </div>
        <div class="camp-info-card">
          
          <h3>Trikot inklusive</h3>
          <p>Der Preis von <strong>99 €</strong> beinhaltet ein Trikot. Damit die Trikots rechtzeitig fertig sind, ist der Anmeldeschluss der <strong>10. Juni</strong>.</p>
	  <p>Der gesamte Erlös fließt in die Förderung unserer Jugendarbeit.</p>
        </div>
        <div class="camp-info-card">
          <h3>Rabatte</h3>
          <p>Bei Anmeldung mehrerer Geschwister erhält jedes weitere Kind <strong>10% Geschwisterrabatt</strong>. Der Rabatt wird automatisch bei der Anmeldung berechnet.</p>
        </div>
      </div>

      <!-- Photo grid placeholder -->
      <div class="section-eyebrow" style="margin-top:3rem; margin-bottom:1rem">Impressionen vom letzten Camp</div>
      <div class="camp-photo-grid">
        <div class="camp-photo-placeholder">
          <img src="/images/camp/camp1.jpg" alt="Camp Impression" class="camp-photo-img" />
        </div>
        <div class="camp-photo-placeholder camp-photo-placeholder--tall">
          <img src="/images/camp/camp2.jpg" alt="Camp Impression" class="camp-photo-img" />
        </div>
        <div class="camp-photo-placeholder">
          <img src="/images/camp/camp3.jpg" alt="Camp Impression" class="camp-photo-img" />
        </div>
        <div class="camp-photo-placeholder">
          <img src="/images/camp/camp4.jpg" alt="Camp Impression" class="camp-photo-img" />
        </div>
        <div class="camp-photo-placeholder camp-photo-placeholder--wide">
          <img src="/images/camp/camp5.jpg" alt="Camp Impression" class="camp-photo-img" />
        </div>
      </div>
      <p class="photo-credit">Fotos freundlicherweise zur Verfügung gestellt von <a href="https://www.thomasldietz.coach/index.php/de/" target="_blank" rel="noopener">Thomas Dietz</a></p>

      <!-- Sign-up form -->
      <div class="camp-form-wrap" id="anmeldung">
        <div class="camp-form-head">
          <h2>Jetzt anmelden</h2>
          <p>Füll das Formular aus und wir melden uns bei dir.</p>
        </div>

        <div class="camp-form-body" id="form-body">

          <!-- Contact details (shared for all players) -->
          <div class="field-section-label">Kontaktdaten</div>
          <div class="field-grid">
            <div class="field-group full">
              <label class="field-label" for="strasse">Straße, Haus-Nr. <span class="req">*</span></label>
              <input class="field-input" type="text" id="strasse" autocomplete="street-address" placeholder="Musterstraße 12" />
              <div class="field-err" id="err-strasse">Pflichtfeld.</div>
            </div>
            <div class="field-group">
              <label class="field-label" for="plz">PLZ <span class="req">*</span></label>
              <input class="field-input" type="text" id="plz" autocomplete="postal-code" placeholder="90411" maxlength="5" />
              <div class="field-err" id="err-plz">Bitte 5-stellige PLZ.</div>
            </div>
            <div class="field-group">
              <label class="field-label" for="ort">Ort <span class="req">*</span></label>
              <input class="field-input" type="text" id="ort" autocomplete="address-level2" placeholder="Nürnberg" />
              <div class="field-err" id="err-ort">Pflichtfeld.</div>
            </div>
            <div class="field-group">
              <label class="field-label" for="telefon">Telefon <span class="req">*</span></label>
              <input class="field-input" type="tel" id="telefon" autocomplete="tel" placeholder="+49 911 …" />
              <div class="field-err" id="err-telefon">Pflichtfeld.</div>
            </div>
            <div class="field-group">
              <label class="field-label" for="email">E-Mail <span class="req">*</span></label>
              <input class="field-input" type="email" id="email" autocomplete="email" placeholder="max@beispiel.de" />
              <div class="field-hint">Für die Bestätigungs-E-Mail und Rechnung.</div>
              <div class="field-err" id="err-email">Bitte gültige E-Mail-Adresse angeben.</div>
            </div>
          </div>

          <!-- Players container -->
          <div id="players-container"></div>

          <!-- Add player button -->
          <div class="discount-hint">
            💡 Melden sich mehrere Geschwister an? Jedes weitere Kind erhält automatisch <strong>10% Geschwisterrabatt</strong>.
          </div>
          <button type="button" class="btn-add-player" id="btn-add-player">
            + Weiteren Spieler hinzufügen
          </button>

          <!-- Price summary -->
          <div class="price-summary" id="price-summary">
            <div class="price-summary-title">Kostenübersicht</div>
            <div id="price-rows"></div>
            <div class="price-total-row">
              <span>Gesamt</span>
              <span id="price-total">99,00 €</span>
            </div>
          </div>

          <div class="field-group full" style="margin-top:1rem">
            <label class="field-label" for="sonstiges">Sonstiges</label>
            <textarea class="field-input" id="sonstiges" rows="3" placeholder="Gesundheitliche Hinweise, Besonderheiten, Fragen…"></textarea>
            <div class="field-hint">z.B. Allergien, gesundheitliche Einschränkungen oder sonstige Informationen für uns.</div>
          </div>

          <div class="camp-form-notice">
            🔒 Deine Daten werden ausschließlich für die Organisation des Sommercamps verwendet und anschließend gelöscht.
          </div>

          <button class="btn-camp-submit" id="btn-submit">
            <span id="btn-text">Jetzt verbindlich anmelden →</span>
            <span id="btn-spinner" class="spinner" style="display:none"></span>
          </button>

        </div><!-- /form-body -->

        <!-- Success state -->
        <div class="camp-success" id="form-success" style="display:none">
          <div class="camp-success-icon">🎉</div>
          <h3>Anmeldung eingereicht!</h3>
          <p>Vielen Dank, <strong id="success-name"></strong>! Wir haben deine Anmeldung erhalten.</p>
          <div class="success-id" id="success-id"></div>
          <p style="color:var(--muted);font-size:.88rem;margin-top:.5rem">Du erhältst in Kürze eine Bestätigungs-E-Mail.</p>
        </div>

      </div><!-- /camp-form-wrap -->
    </div>
  </section>

</BaseLayout>

<style is:global>
  .camp-hero {
    background: var(--navy);
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }
  .camp-hero h1 { color: var(--white); }
  .camp-hero h1 em { color: var(--orange); font-style: normal; }
  .camp-hero .section-eyebrow { color: rgba(255,255,255,.5); }
  .camp-hero .section-eyebrow::before { background: var(--orange); }

  .camp-meta {
    display: flex; flex-wrap: wrap; gap: .75rem 1.5rem;
    margin-top: 1rem;
  }
  .camp-meta-item {
    font-size: .95rem; color: rgba(255,255,255,.75);
    display: flex; align-items: center; gap: .4rem;
  }

  .camp-container { max-width: 860px; }

  /* Alert */
  .camp-alert {
    background: var(--orange);
    color: var(--white);
    border-radius: var(--radius-lg);
    padding: 1rem 1.5rem;
    display: flex; align-items: center; gap: 1rem;
    font-size: .95rem; font-weight: 500;
    margin-bottom: 2.5rem;
  }
  .camp-alert-icon { font-size: 1.5rem; flex-shrink: 0; }
  .camp-alert strong { font-weight: 700; }

  /* Info cards */
  .camp-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .camp-info-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.25rem;
    transition: box-shadow .2s, transform .2s;
  }
  .camp-info-card:hover { box-shadow: var(--shadow-md, 0 4px 20px rgba(15,41,114,.1)); transform: translateY(-2px); }
  .camp-info-icon { font-size: 2rem; margin-bottom: .75rem; }
  .camp-info-card h3 { font-size: 1.1rem; color: var(--navy); margin-bottom: .5rem; }
  .camp-info-card p { font-size: .875rem; color: var(--mid); line-height: 1.6; }

  /* Photo grid */
  .camp-photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 180px 180px;
    gap: .75rem;
    margin-bottom: 3rem;
  }
  .camp-photo-placeholder {
    background: var(--navy-pale);
    border-radius: var(--radius-lg);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: .5rem; color: var(--navy-mid);
    font-size: .8rem; font-weight: 600;
    letter-spacing: .05em; text-transform: uppercase;
  }
  .camp-photo-placeholder span { font-size: 2rem; opacity: .4; }
  .camp-photo-img { width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-lg); display: block; }
  .photo-credit { font-size: .78rem; color: var(--muted); margin-top: .75rem; margin-bottom: 2rem; }
  .photo-credit a { color: var(--navy); text-decoration: underline; }
  .photo-credit a:hover { color: var(--orange); }
  .camp-photo-placeholder--tall { grid-row: span 2; }
  .camp-photo-placeholder--wide { grid-column: span 2; }

  /* Form wrap */
  .camp-form-wrap {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(15,41,114,.07);
    margin-bottom: 3rem;
  }
  .camp-form-head {
    background: var(--navy);
    padding: 1.5rem 2rem;
    border-bottom: 3px solid var(--orange);
  }
  .camp-form-head h2 { font-family: var(--fd); font-size: 1.8rem; color: var(--white); }
  .camp-form-head p { color: rgba(255,255,255,.6); font-size: .9rem; margin-top: .3rem; }
  .camp-form-body { padding: 2rem; }

  /* Reuse field styles from membership form */
  .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .field-grid .full { grid-column: 1 / -1; }
  .field-group { display: flex; flex-direction: column; gap: .35rem; }
  .field-label { font-size: .8rem; font-weight: 600; color: var(--mid); }
  .req { color: #dc2626; }
  .field-input { border: 2px solid var(--border); border-radius: var(--radius); padding: .6rem .85rem; font-family: var(--fb); font-size: .95rem; color: var(--ink); background: var(--white); transition: border-color .15s; width: 100%; }
  .field-input:focus { outline: none; border-color: var(--navy); box-shadow: 0 0 0 3px rgba(15,41,114,.1); }
  .field-input.error { border-color: #dc2626; }
  textarea.field-input { resize: vertical; }
  .field-err { font-size: .75rem; color: #dc2626; font-weight: 500; display: none; }
  .field-err.visible { display: block; }
  .field-hint { font-size: .74rem; color: var(--muted); }

  .camp-form-notice {
    background: var(--navy-tint);
    border-radius: var(--radius);
    padding: .75rem 1rem;
    font-size: .82rem;
    color: var(--navy);
    margin-top: 1.5rem;
  }

  .btn-camp-submit {
    display: flex; align-items: center; justify-content: center; gap: .5rem;
    width: 100%; margin-top: 1.25rem;
    background: var(--orange); color: var(--white);
    border: none; border-radius: var(--radius);
    padding: 1rem; font-family: var(--fd);
    font-size: 1.2rem; letter-spacing: .04em;
    cursor: pointer; transition: background .15s;
  }
  .btn-camp-submit:hover { background: #c96508; }
  .btn-camp-submit:disabled { opacity: .6; cursor: not-allowed; }

  /* Success */
  .camp-success { text-align: center; padding: 3rem 2rem; }
  .camp-success-icon { font-size: 3rem; margin-bottom: 1rem; }
  .camp-success h3 { font-family: var(--fd); font-size: 2rem; color: var(--navy); margin-bottom: .5rem; }
  .camp-success p { color: var(--mid); }
  .success-id {
    display: inline-block; background: var(--navy); color: var(--orange);
    font-family: var(--fd); font-size: 1.2rem; letter-spacing: .08em;
    padding: .4rem 1.25rem; border-radius: var(--radius); margin: .75rem 0;
  }

  .spinner { display: inline-block; width: 18px; height: 18px; border: 2px solid rgba(255,255,255,.3); border-top-color: white; border-radius: 50%; animation: spin .7s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Section label */
  .field-section-label { font-size: .67rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--navy); margin-bottom: .75rem; margin-top: 1.5rem; display: flex; align-items: center; gap: .6rem; }
  .field-section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  /* Player card */
  .player-card { border: 2px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem; margin-top: 1.5rem; position: relative; }
  .player-card.player-card--primary { border-color: var(--navy); }
  .player-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  .player-card-title { font-family: var(--fd); font-size: 1.1rem; color: var(--navy); letter-spacing: .03em; }
  .btn-remove-player { background: transparent; border: 1px solid #fecaca; color: var(--red, #dc2626); border-radius: var(--radius); padding: .3em .8em; font-size: .78rem; font-weight: 600; cursor: pointer; font-family: var(--fb); }
  .btn-remove-player:hover { background: #fef2f2; }

  /* Voucher */
  .voucher-row { display: flex; gap: .5rem; align-items: flex-start; }
  .voucher-row .field-input { flex: 1; text-transform: uppercase; letter-spacing: .05em; }
  .btn-voucher { background: var(--navy); color: var(--white); border: none; border-radius: var(--radius); padding: .6rem 1rem; font-family: var(--fb); font-size: .85rem; font-weight: 600; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
  .btn-voucher:hover { background: var(--navy-dark); }
  .voucher-ok { font-size: .78rem; color: var(--green, #16a34a); font-weight: 600; margin-top: .3rem; display: none; }
  .voucher-ok.visible { display: block; }
  .voucher-err { font-size: .78rem; color: #dc2626; font-weight: 600; margin-top: .3rem; display: none; }
  .voucher-err.visible { display: block; }

  /* Add player button */
  .discount-hint { background: var(--navy-tint); border: 1px solid var(--navy-pale); border-radius: var(--radius); padding: .75rem 1rem; font-size: .85rem; color: var(--navy); margin-top: 1.5rem; line-height: 1.5; }
  .discount-hint strong { font-weight: 700; }
  .btn-add-player { display: flex; align-items: center; gap: .5rem; margin-top: 1.25rem; background: var(--navy-tint); color: var(--navy); border: 2px dashed var(--navy-pale); border-radius: var(--radius-lg); padding: .85rem 1.25rem; font-family: var(--fb); font-size: .9rem; font-weight: 600; cursor: pointer; width: 100%; justify-content: center; transition: all .15s; }
  .btn-add-player:hover { background: var(--navy-pale); border-color: var(--navy); }

  /* Price summary */
  .price-summary { background: var(--navy); border-radius: var(--radius-lg); padding: 1.25rem 1.5rem; margin-top: 1.5rem; }
  .price-summary-title { font-family: var(--fd); font-size: 1rem; color: rgba(255,255,255,.5); letter-spacing: .06em; text-transform: uppercase; margin-bottom: .75rem; }
  .price-row { display: flex; justify-content: space-between; align-items: center; font-size: .9rem; color: rgba(255,255,255,.7); padding: .3rem 0; border-bottom: 1px solid rgba(255,255,255,.08); }
  .price-row span:last-child { font-weight: 600; color: var(--white); }
  .price-row .discount { color: #86efac; font-size: .78rem; }
  .price-total-row { display: flex; justify-content: space-between; align-items: center; margin-top: .75rem; }
  .price-total-row span:first-child { font-family: var(--fd); font-size: 1.1rem; color: rgba(255,255,255,.6); letter-spacing: .04em; }
  .price-total-row span:last-child { font-family: var(--fd); font-size: 2rem; color: var(--orange); line-height: 1; }

  @media (max-width: 600px) {
    .field-grid { grid-template-columns: 1fr; }
    .field-grid .full { grid-column: 1; }
    .camp-photo-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
    .camp-photo-placeholder--tall { grid-row: span 1; }
    .camp-photo-placeholder--wide { grid-column: span 2; }
    .camp-info-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
(() => {
  // ── Countdown ─────────────────────────────────────────────
  const deadline = new Date("2026-06-10");
  const diff = Math.ceil((deadline - new Date()) / (1000 * 60 * 60 * 24));
  const el = document.getElementById('days-left');
  if (el) el.textContent = diff > 0 ? `noch ${diff} Tage` : diff === 0 ? 'letzter Tag' : 'Anmeldeschluss abgelaufen';

  const $ = id => document.getElementById(id);
  const val = id => { const e = $(id); return e ? e.value.trim() : ''; };

  const BASE_PRICE = 99;
  const SIBLING_DISCOUNT = 0.10;
  const TRAINER_CODE = 'ASN-TRAINER-BONUS';

  // ── Player state ──────────────────────────────────────────
  let players = []; // { id, voucher, voucherValid, voucherApplied }
  let playerCount = 0;

  function trikotOptions() {
    return ['164 (Junior)','XS (Erw.)','S (Erw.)','M (Erw.)','L (Erw.)','XL (Erw.)','XXL (Erw.)','XXXL (Erw.)']
      .map(o => `<option value="${o}">${o}</option>`).join('');
  }

  function createPlayerCard(idx) {
    const id = ++playerCount;
    const isPrimary = idx === 0;
    const label = isPrimary ? 'Spieler 1 (Hauptanmelder)' : `Spieler ${idx + 1}`;
    players.push({ id, voucher: '', voucherValid: false });

    const card = document.createElement('div');
    card.className = `player-card ${isPrimary ? 'player-card--primary' : ''}`;
    card.dataset.playerId = id;
    card.innerHTML = `
      <div class="player-card-header">
        <div class="player-card-title">${label}</div>
        ${!isPrimary ? `<button type="button" class="btn-remove-player" onclick="removePlayer(${id})">✕ Entfernen</button>` : ''}
      </div>
      <div class="field-grid">
        <div class="field-group">
          <label class="field-label">Vorname <span class="req">*</span></label>
          <input class="field-input" type="text" id="p${id}-vorname" placeholder="Max" />
          <div class="field-err" id="p${id}-err-vorname">Pflichtfeld.</div>
        </div>
        <div class="field-group">
          <label class="field-label">Nachname <span class="req">*</span></label>
          <input class="field-input" type="text" id="p${id}-nachname" placeholder="Mustermann" />
          <div class="field-err" id="p${id}-err-nachname">Pflichtfeld.</div>
        </div>
        <div class="field-group">
          <label class="field-label">Geburtsdatum <span class="req">*</span></label>
          <input class="field-input" type="date" id="p${id}-geburtsdatum" onchange="checkAge(${id})" />
          <div class="field-err" id="p${id}-err-geburtsdatum">Pflichtfeld.</div>
        </div>
        <div class="field-group">
          <label class="field-label">Geschlecht <span class="req">*</span></label>
          <select class="field-input" id="p${id}-geschlecht">
            <option value="">— bitte wählen —</option>
            <option value="männlich">männlich</option>
            <option value="weiblich">weiblich</option>
            <option value="divers">divers</option>
          </select>
          <div class="field-err" id="p${id}-err-geschlecht">Bitte wählen.</div>
        </div>
        <div class="field-group">
          <label class="field-label">Team <span class="req">*</span></label>
          <select class="field-input" id="p${id}-team">
            <option value="">— bitte wählen —</option>
            <option>A-Jugend</option><option>B-Jugend</option>
            <option>C-Jugend</option><option>D-Jugend</option>
            <option>Mädels</option>
          </select>
          <div class="field-err" id="p${id}-err-team">Bitte wählen.</div>
        </div>
        <div class="field-group">
          <label class="field-label">Trikotgröße <span class="req">*</span></label>
          <select class="field-input" id="p${id}-trikot">
            <option value="">— bitte wählen —</option>
            ${trikotOptions()}
          </select>
          <div class="field-err" id="p${id}-err-trikot">Bitte wählen.</div>
        </div>
        <div class="field-group full" id="p${id}-erz-group" style="display:none">
          <label class="field-label">Erziehungsberechtigter <span class="req">*</span></label>
          <input class="field-input" type="text" id="p${id}-erziehungsberechtigter" placeholder="Vorname Nachname" />
          <div class="field-err" id="p${id}-err-erziehungsberechtigter">Pflichtfeld für Minderjährige.</div>
        </div>
        <div class="field-group full">
          <label class="field-label">Gutscheincode</label>
          <div class="voucher-row">
            <input class="field-input" type="text" id="p${id}-voucher" placeholder="z.B. ASN-TRAINER-BONUS" style="text-transform:uppercase" />
            <button type="button" class="btn-voucher" onclick="applyVoucher(${id})">Einlösen</button>
          </div>
          <div class="voucher-ok" id="p${id}-voucher-ok">✓ Gutschein eingelöst — kostenlose Teilnahme</div>
          <div class="voucher-err" id="p${id}-voucher-err">Ungültiger Gutscheincode.</div>
        </div>
      </div>
    `;
    $('players-container').appendChild(card);
    updatePriceSummary();
  }

  window.removePlayer = function(id) {
    players = players.filter(p => p.id !== id);
    const card = document.querySelector(`[data-player-id="${id}"]`);
    if (card) card.remove();
    // Renumber labels
    document.querySelectorAll('.player-card').forEach((c, i) => {
      const title = c.querySelector('.player-card-title');
      if (title) title.textContent = i === 0 ? 'Spieler 1 (Hauptanmelder)' : `Spieler ${i + 1}`;
    });
    updatePriceSummary();
  };

  window.checkAge = function(id) {
    const dob = new Date(document.getElementById(`p${id}-geburtsdatum`)?.value || '');
    const age = Math.floor((new Date() - dob) / (365.25 * 24 * 60 * 60 * 1000));
    const group = $(`p${id}-erz-group`);
    if (group) group.style.display = age < 18 ? '' : 'none';
  };

  window.applyVoucher = function(id) {
    const input = $(`p${id}-voucher`);
    const code = (input?.value || '').trim().toUpperCase();
    const player = players.find(p => p.id === id);
    const okEl = $(`p${id}-voucher-ok`);
    const errEl = $(`p${id}-voucher-err`);
    if (!player) return;
    if (code === TRAINER_CODE) {
      player.voucher = code;
      player.voucherValid = true;
      okEl?.classList.add('visible');
      errEl?.classList.remove('visible');
      if (input) input.classList.remove('error');
    } else {
      player.voucher = '';
      player.voucherValid = false;
      okEl?.classList.remove('visible');
      errEl?.classList.add('visible');
      if (input) input.classList.add('error');
    }
    updatePriceSummary();
  };

  function calcPrice(playerIdx, voucherValid) {
    if (voucherValid) return 0;
    if (playerIdx === 0) return BASE_PRICE;
    return Math.round(BASE_PRICE * (1 - SIBLING_DISCOUNT) * 100) / 100;
  }

  function updatePriceSummary() {
    const rowsEl = $('price-rows');
    const totalEl = $('price-total');
    if (!rowsEl || !totalEl) return;
    let total = 0;
    rowsEl.innerHTML = players.map((p, i) => {
      const nameEl = document.getElementById(`p${p.id}-vorname`);
      const name = nameEl?.value.trim() || `Spieler ${i + 1}`;
      const price = calcPrice(i, p.voucherValid);
      total += price;
      const discount = i > 0 && !p.voucherValid ? ' <span class="discount">(−10% Geschwisterrabatt)</span>' : '';
      const priceStr = p.voucherValid ? 'Kostenlos' : `${price.toFixed(2).replace('.', ',')} €`;
      return `<div class="price-row"><span>${name}${discount}</span><span>${priceStr}</span></div>`;
    }).join('');
    totalEl.textContent = `${total.toFixed(2).replace('.', ',')} €`;
  }

  // Update price summary when names change
  $('players-container').addEventListener('input', e => {
    if (e.target.id?.endsWith('-vorname')) updatePriceSummary();
  });

  // Add player button — max 4
  $('btn-add-player').addEventListener('click', () => {
    if (players.length >= 4) {
      alert('Maximal 4 Spieler pro Anmeldung.');
      return;
    }
    createPlayerCard(players.length);
  });

  // ── Validation ────────────────────────────────────────────
  function showErr(errId, visible) {
    const e = $(errId);
    if (e) e.classList.toggle('visible', visible);
    const inp = document.getElementById(errId.replace('err-', ''));
    if (inp) inp.classList.toggle('error', visible);
  }

  function validateContact() {
    let ok = true;
    [
      { id: 'strasse', check: v => v.length > 0 },
      { id: 'plz',     check: v => /^\d{5}$/.test(v) },
      { id: 'ort',     check: v => v.length > 0 },
      { id: 'telefon', check: v => v.length > 0 },
      { id: 'email',   check: v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) },
    ].forEach(f => {
      const valid = f.check(val(f.id));
      showErr(`err-${f.id}`, !valid);
      if (!valid) ok = false;
    });
    return ok;
  }

  function validatePlayers() {
    let ok = true;
    players.forEach((p, i) => {
      const pid = `p${p.id}`;
      [
        { field: 'vorname',    check: v => v.length > 0 },
        { field: 'nachname',   check: v => v.length > 0 },
        { field: 'geburtsdatum', check: v => v.length > 0 },
        { field: 'geschlecht', check: v => v.length > 0 },
        { field: 'team',       check: v => v.length > 0 },
        { field: 'trikot',     check: v => v.length > 0 },
      ].forEach(f => {
        const el = $(`${pid}-${f.field}`);
        const v = el ? el.value.trim() : '';
        const valid = f.check(v);
        const errEl = $(`${pid}-err-${f.field}`);
        if (errEl) errEl.classList.toggle('visible', !valid);
        if (el) el.classList.toggle('error', !valid);
        if (!valid) ok = false;
      });
      // Parent field
      const erzGroup = $(`${pid}-erz-group`);
      if (erzGroup && erzGroup.style.display !== 'none') {
        const erzEl = $(`${pid}-erziehungsberechtigter`);
        const erzOk = (erzEl?.value.trim() || '').length > 0;
        const erzErr = $(`${pid}-err-erziehungsberechtigter`);
        if (erzErr) erzErr.classList.toggle('visible', !erzOk);
        if (erzEl) erzEl.classList.toggle('error', !erzOk);
        if (!erzOk) ok = false;
      }
    });
    return ok;
  }

  // ── Submit ────────────────────────────────────────────────
  $('btn-submit').addEventListener('click', async () => {
    const contactOk = validateContact();
    const playersOk = validatePlayers();
    if (!contactOk || !playersOk) return;

    const btn = $('btn-submit');
    $('btn-text').style.display = 'none';
    $('btn-spinner').style.display = '';
    btn.disabled = true;

    const spielerData = players.map((p, i) => {
      const pid = `p${p.id}`;
      const get = field => document.getElementById(`${pid}-${field}`)?.value.trim() || '';
      return {
        vorname:               get('vorname'),
        nachname:              get('nachname'),
        geburtsdatum:          get('geburtsdatum'),
        geschlecht:            get('geschlecht'),
        team:                  get('team'),
        trikot_groesse:        get('trikot'),
        erziehungsberechtigter: get('erziehungsberechtigter') || null,
        voucher_code:          p.voucherValid ? p.voucher : null,
        preis:                 calcPrice(i, p.voucherValid),
        spieler_nr:            i + 1,
      };
    });

    const payload = {
      strasse:    val('strasse'),
      plz:        val('plz'),
      ort:        val('ort'),
      telefon:    val('telefon'),
      email:      val('email'),
      sonstiges:  val('sonstiges'),
      spieler:    spielerData,
    };

    try {
      const res = await fetch('/api/submit-camp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (res.ok && data.success) {
        $('form-body').style.display = 'none';
        $('form-success').style.display = '';
        $('success-name').textContent = spielerData[0] ? `${spielerData[0].vorname} ${spielerData[0].nachname}` : '';
        $('success-id').textContent = `Anmeldung-ID: ${data.anmeldungId}`;
        window.scrollTo({ top: document.getElementById('anmeldung').offsetTop - 80, behavior: 'smooth' });
      } else {
        throw new Error(data.error || 'Unbekannter Fehler');
      }
    } catch (err) {
      alert(`Fehler: ${err.message}\n\nBitte erneut versuchen oder den Verein kontaktieren.`);
      $('btn-text').style.display = '';
      $('btn-spinner').style.display = 'none';
      btn.disabled = false;
    }
  });

  // ── Init: create first player card ───────────────────────
  createPlayerCard(0);
})();
</script>
