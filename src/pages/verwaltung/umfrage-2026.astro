// ── CSV Export ────────────────────────────────────────────────
window.downloadCsv = function() {
  const rows = window.__surveyRows__ || [];
  if (!rows.length) { showToast('Keine Daten', 'error'); return; }

  const cols = [
    'code','status','sprache','eingegangen_am','abgeschlossen_am',
    'q1_fuer_wen','q2_abteilungen','q2_jugend_ag','q3_altersgruppe','q4_mitgliedschaft','q4_sonstiges','q5_dauer',
    'q6_gruende','q6_sonstiges','q7_top3','q7_sonstiges','q8_verbundenheit','q8a_freitext',
    'q9_heute','q9_zukunft','q10_heute','q10_zukunft','q11_heute','q11_zukunft','q12_heute','q12_zukunft','q13_freitext',
    'q14_umkleide','q14_plaetze','q14_einrichtungen','q14_sauberkeit','q14_kommunikation',
    'q15_freitext','q16_freitext',
    'q17_ehrenamt','q18_freitext','q19_skillsboerse','q20_freitext','q21_stunden','q22_leichter','q22_sonstiges',
    'q23_preis_leistung','q24_erhoehung','q25_top3','q25_sonstiges',
    'q30_gruppen','q31_kontakt',
    'q26_freitext','q27_freitext','q28_freitext','q29_freitext',
  ];

  const escape = v => {
    if (v === null || v === undefined) return '';
    const s = Array.isArray(v) ? v.join(', ') : String(v);
    return s.includes(';') || s.includes('"') || s.includes('\n') ? `"${s.replace(/"/g,'""')}"` : s;
  };

  const header = cols.join(';');
  const body = rows.map(r => cols.map(c => escape(r[c])).join(';')).join('\n');
  const csv = '\uFEFF' + header + '\n' + body;
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href = url; a.download = 'umfrage-2026.csv'; a.click();
  URL.revokeObjectURL(url);
  showToast(`${rows.length} Antworten exportiert`, 'success');
};

// ── Load & render ─────────────────────────────────────────────
window.loadAndRender = async function() {
  document.getElementById('admin-content').innerHTML = '<div class="loading-state"><div class="spinner"></div></div>';
  try {
    const rows = await loadData();
    renderDashboard(rows);
  } catch(err) {
    document.getElementById('admin-content').innerHTML = `<div style="color:var(--red);padding:2rem">Fehler: ${err.message}</div>`;
  }
};

// ── Login ─────────────────────────────────────────────────────
async function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  const password = document.getElementById('login-password').value;
  const errEl = document.getElementById('login-error');
  errEl.classList.remove('visible');
  document.getElementById('login-btn-text').style.display = 'none';
  document.getElementById('login-spinner').style.display = 'inline-block';
  document.getElementById('btn-login').disabled = true;
  try {
    const res = await fetch(`${SUPABASE_URL}/auth/v1/token?grant_type=password`, {
      method: 'POST',
      headers: { 'Content-Type':'application/json','apikey':SUPABASE_KEY },
      body: JSON.stringify({ email, password }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error_description || data.msg || 'Login fehlgeschlagen');
    accessToken = data.access_token;
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('admin-wrap').classList.add('visible');
    document.getElementById('header-user').textContent = email;
    loadAndRender();
  } catch(err) {
    errEl.textContent = err.message; errEl.classList.add('visible');
  } finally {
    document.getElementById('login-btn-text').style.display = '';
    document.getElementById('login-spinner').style.display = 'none';
    document.getElementById('btn-login').disabled = false;
  }
}

document.getElementById('btn-login').addEventListener('click', doLogin);
document.getElementById('login-password').addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });
document.getElementById('btn-logout').addEventListener('click', async () => {
  await fetch(`${SUPABASE_URL}/auth/v1/logout`, {
    method:'POST', headers:{'Content-Type':'application/json','apikey':SUPABASE_KEY,'Authorization':`Bearer ${accessToken}`}
  });
  accessToken = null;
  document.getElementById('admin-wrap').classList.remove('visible');
  document.getElementById('login-screen').style.display = '';
  showToast('Ausgeloggt');
});
</script>
