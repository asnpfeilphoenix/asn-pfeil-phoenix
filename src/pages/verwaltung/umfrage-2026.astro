---
// src/pages/verwaltung/umfrage-2026.astro
export const prerender = false;
const SUPABASE_URL  = import.meta.env.SUPABASE_URL  || '';
const SUPABASE_ANON = import.meta.env.SUPABASE_ANON_KEY || '';
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Umfrage-Auswertung 2026 — ASN Pfeil Phönix</title>
  <meta name="robots" content="noindex, nofollow" />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #0f2972; --navy-dark: #091d52; --navy-pale: #e8edf8; --navy-tint: #f0f3fc;
      --orange: #E8780A; --white: #fff; --ink: #111318; --mid: #4A4F5C; --muted: #8A8F9E;
      --border: #E4E6EE; --green: #16a34a; --red: #dc2626;
      --fd: 'Bebas Neue', sans-serif; --fb: 'DM Sans', sans-serif;
      --radius: 6px; --radius-lg: 12px;
    }
    body { font-family: var(--fb); background: #f0f2f8; color: var(--ink); min-height: 100vh; }

    /* ── Header ──────────────────────────────────────────────── */
    .header { background: var(--navy); border-bottom: 3px solid var(--orange); padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .header-brand { display: flex; align-items: center; gap: .75rem; }
    .header-brand img { width: 40px; height: 40px; }
    .header-brand-text strong { display: block; font-family: var(--fd); font-size: 1.2rem; color: var(--white); letter-spacing: .04em; }
    .header-brand-text span { font-size: .72rem; color: rgba(255,255,255,.45); letter-spacing: .1em; text-transform: uppercase; }
    .header-right { display: flex; align-items: center; gap: 1rem; }
    .header-badge { font-size: .72rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; background: rgba(232,120,10,.2); color: var(--orange); border: 1px solid rgba(232,120,10,.3); padding: .3em .8em; border-radius: 99px; }
    .header-user { font-size: .82rem; color: rgba(255,255,255,.5); }
    .btn-logout { font-family: var(--fb); font-size: .82rem; font-weight: 600; background: transparent; border: 1px solid rgba(255,255,255,.2); color: rgba(255,255,255,.6); padding: .4em 1em; border-radius: var(--radius); cursor: pointer; }
    .btn-logout:hover { border-color: rgba(255,255,255,.5); color: var(--white); }

    /* ── Login ───────────────────────────────────────────────── */
    .login-wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem; background: var(--navy-dark); }
    .login-card { background: var(--white); border-radius: var(--radius-lg); padding: 2.5rem; width: 100%; max-width: 400px; box-shadow: 0 20px 60px rgba(0,0,0,.4); }
    .login-logo { display: flex; align-items: center; gap: .75rem; margin-bottom: 2rem; }
    .login-logo img { width: 48px; }
    .login-logo-text strong { display: block; font-family: var(--fd); font-size: 1.3rem; color: var(--navy); }
    .login-logo-text span { font-size: .72rem; color: var(--muted); letter-spacing: .1em; text-transform: uppercase; }
    .login-title { font-family: var(--fd); font-size: 1.8rem; color: var(--navy); margin-bottom: .4rem; }
    .login-sub { font-size: .85rem; color: var(--muted); margin-bottom: 1.75rem; }
    .field { display: flex; flex-direction: column; gap: .35rem; margin-bottom: 1rem; }
    .field label { font-size: .8rem; font-weight: 600; color: var(--mid); }
    .field input { border: 2px solid var(--border); border-radius: var(--radius); padding: .65rem .85rem; font-family: var(--fb); font-size: .95rem; width: 100%; }
    .field input:focus { outline: none; border-color: var(--navy); }
    .btn-login { width: 100%; background: var(--navy); color: var(--white); border: none; border-radius: var(--radius); padding: .8rem; font-family: var(--fd); font-size: 1.1rem; letter-spacing: .04em; cursor: pointer; margin-top: .5rem; }
    .login-error { background: #fef2f2; border: 1px solid #fecaca; color: var(--red); border-radius: var(--radius); padding: .75rem 1rem; font-size: .85rem; margin-top: 1rem; display: none; }
    .login-error.visible { display: block; }

    /* ── Admin layout ────────────────────────────────────────── */
    .admin-wrap { display: none; }
    .admin-wrap.visible { display: block; }
    .admin-main { max-width: 1060px; margin: 0 auto; padding: 2rem 1.5rem; }

    /* ── Stats bar ───────────────────────────────────────────── */
    .stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
    .stat-card { background: var(--white); border-radius: var(--radius-lg); padding: 1.25rem 1.5rem; border: 1px solid var(--border); box-shadow: 0 1px 4px rgba(15,41,114,.06); }
    .stat-card__val { font-family: var(--fd); font-size: 3rem; color: var(--navy); line-height: 1; }
    .stat-card__label { font-size: .72rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); margin-top: .4rem; }

    /* ── Toolbar ─────────────────────────────────────────────── */
    .toolbar { display: flex; gap: .75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .btn-tool { background: var(--white); color: var(--navy); border: 1px solid var(--border); border-radius: var(--radius); padding: .6em 1.1em; font-family: var(--fd); font-size: .95rem; letter-spacing: .03em; cursor: pointer; box-shadow: 0 1px 4px rgba(0,0,0,.06); }
    .btn-tool:hover { background: var(--navy-pale); }
    .btn-tool--primary { background: var(--navy); color: var(--white); border-color: var(--navy); }
    .btn-tool--primary:hover { background: var(--navy-dark); }
    .btn-tool--danger { background: var(--white); color: var(--red); border-color: #fecaca; }
    .btn-tool--danger:hover { background: #fef2f2; }

    /* ── Tabs ────────────────────────────────────────────────── */
    .tabs { display: flex; gap: 0; margin-bottom: 1.5rem; background: var(--white); border-radius: var(--radius-lg); border: 1px solid var(--border); overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,.06); }
    .tab { flex: 1; padding: .85rem 1rem; text-align: center; font-family: var(--fd); font-size: 1rem; letter-spacing: .04em; cursor: pointer; color: var(--muted); border: none; background: transparent; transition: all .15s; }
    .tab.active { background: var(--navy); color: var(--white); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* ── Section card ────────────────────────────────────────── */
    .section-card { background: var(--white); border-radius: var(--radius-lg); border: 1px solid var(--border); margin-bottom: 1.25rem; overflow: hidden; box-shadow: 0 1px 4px rgba(15,41,114,.06); }
    .section-head { padding: 1rem 1.5rem; border-bottom: 3px solid var(--orange); background: var(--navy); display: flex; align-items: center; }
    .section-title { font-family: var(--fd); font-size: 1.1rem; color: var(--white); letter-spacing: .04em; }
    .section-body { padding: 1.5rem; }

    /* ── Q-stat block ────────────────────────────────────────── */
    .q-stat { margin-bottom: 1.75rem; padding-bottom: 1.75rem; border-bottom: 1px solid var(--border); }
    .q-stat:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .q-num { font-size: .67rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--orange); margin-bottom: .25rem; }
    .q-title { font-size: .95rem; font-weight: 600; color: var(--ink); margin-bottom: 1rem; line-height: 1.5; }
    .q-empty { font-size: .875rem; color: var(--muted); font-style: italic; }
    .q-n { font-weight: 400; font-size: .78rem; color: var(--muted); margin-left: .5rem; }

    /* ── Scale visualisation ─────────────────────────────────── */
    .scale-vis { display: flex; gap: 2rem; align-items: flex-start; flex-wrap: wrap; }
    .scale-mean-box { text-align: center; background: var(--navy); border-radius: var(--radius-lg); padding: 1rem 1.5rem; min-width: 90px; }
    .scale-mean-num { font-family: var(--fd); font-size: 3rem; color: var(--orange); line-height: 1; }
    .scale-mean-lbl { font-size: .67rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.6); margin-top: .25rem; }
    .scale-bars { flex: 1; min-width: 200px; display: flex; flex-direction: column; gap: .4rem; }
    .sbar-row { display: flex; align-items: center; gap: .75rem; }
    .sbar-label { width: 16px; font-size: .78rem; font-weight: 700; color: var(--mid); text-align: right; flex-shrink: 0; }
    .sbar-track { flex: 1; height: 22px; background: var(--navy-pale); border-radius: 4px; overflow: hidden; }
    .sbar-fill { height: 100%; background: var(--navy); border-radius: 4px; min-width: 2px; }
    .sbar-count { width: 28px; font-size: .78rem; color: var(--muted); font-weight: 600; }

    /* ── Frequency visualisation ─────────────────────────────── */
    .freq-list { display: flex; flex-direction: column; gap: .5rem; }
    .fbar-row { display: flex; align-items: center; gap: .75rem; }
    .fbar-label { min-width: 220px; font-size: .875rem; color: var(--ink); flex-shrink: 0; }
    .fbar-track { flex: 1; height: 24px; background: var(--navy-pale); border-radius: 4px; overflow: hidden; min-width: 100px; }
    .fbar-fill { height: 100%; background: var(--orange); border-radius: 4px; min-width: 2px; }
    .fbar-count { width: 36px; font-size: .875rem; font-weight: 700; color: var(--navy); text-align: right; flex-shrink: 0; }

    /* ── Grid scale table ────────────────────────────────────── */
    .grid-table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    .grid-table th { padding: .6rem .75rem; font-size: .67rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--white); background: var(--navy); text-align: center; }
    .grid-table th:first-child { text-align: left; }
    .grid-table td { padding: .65rem .75rem; border-bottom: 1px solid var(--border); }
    .grid-table td:not(:first-child) { text-align: center; color: var(--mid); }
    .grid-table tr:last-child td { border-bottom: none; }
    .grid-table tr:nth-child(even) td { background: #fafbff; }
    .mean-cell { font-family: var(--fd); font-size: 1.2rem; color: var(--orange); font-weight: 700; }

    /* ── Free text list ──────────────────────────────────────── */
    .ftext-list { display: flex; flex-direction: column; gap: .5rem; max-height: 320px; overflow-y: auto; }
    .ftext-item { background: var(--navy-tint); border-left: 3px solid var(--navy); border-radius: 0 var(--radius) var(--radius) 0; padding: .65rem 1rem; font-size: .875rem; color: var(--ink); line-height: 1.55; }

    /* ── Responses table ─────────────────────────────────────── */
    .resp-table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    .resp-table th { padding: .65rem 1rem; font-size: .67rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); border-bottom: 2px solid var(--border); text-align: left; background: #fafafa; }
    .resp-table td { padding: .75rem 1rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
    .resp-table tr:last-child td { border-bottom: none; }
    .resp-table tr:hover td { background: var(--navy-tint); }
    .badge { display: inline-block; font-size: .67rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; padding: .25em .7em; border-radius: 99px; }
    .badge--submitted { background: #dcfce7; color: #166534; }
    .badge--progress { background: #fef9c3; color: #854d0e; }
    .code-mono { font-family: monospace; letter-spacing: .1em; font-weight: 700; color: var(--navy); background: var(--navy-pale); padding: .2em .5em; border-radius: var(--radius); }
    .btn-del { background: transparent; color: var(--red); border: 1px solid #fecaca; border-radius: var(--radius); padding: .3em .8em; font-size: .78rem; font-weight: 600; cursor: pointer; font-family: var(--fb); }
    .btn-del:hover { background: #fef2f2; }

    /* ── Confirm modal ───────────────────────────────────────── */
    .confirm-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 200; display: none; align-items: center; justify-content: center; padding: 1rem; }
    .confirm-overlay.visible { display: flex; }
    .confirm-box { background: var(--white); border-radius: var(--radius-lg); padding: 2rem; max-width: 440px; width: 100%; }
    .confirm-box h3 { font-family: var(--fd); font-size: 1.5rem; color: var(--red); margin-bottom: .75rem; }
    .confirm-box p { font-size: .9rem; color: var(--mid); line-height: 1.6; margin-bottom: 1.5rem; }
    .confirm-btns { display: flex; gap: .75rem; }
    .btn-cancel { flex: 1; background: transparent; border: 2px solid var(--border); color: var(--mid); border-radius: var(--radius); padding: .7rem; font-family: var(--fb); font-size: .9rem; font-weight: 600; cursor: pointer; }
    .btn-confirm-del { flex: 1; background: var(--red); color: var(--white); border: none; border-radius: var(--radius); padding: .7rem; font-family: var(--fb); font-size: .9rem; font-weight: 600; cursor: pointer; }

    /* ── Misc ────────────────────────────────────────────────── */
    .loading { text-align: center; padding: 3rem; color: var(--muted); }
    .spinner { display: inline-block; width: 28px; height: 28px; border: 3px solid var(--border); border-top-color: var(--navy); border-radius: 50%; animation: spin .7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .toast { position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--ink); color: var(--white); padding: .75rem 1.5rem; border-radius: 99px; font-size: .875rem; font-weight: 500; z-index: 300; opacity: 0; transition: all .3s; pointer-events: none; }
    .toast.visible { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast--success { background: var(--green); }
    .toast--error { background: var(--red); }
  </style>
</head>
<body>

<!-- Login -->
<div class="login-wrap" id="login-screen">
  <div class="login-card">
    <div class="login-logo">
      <img src="/images/asn-logo.svg" alt="" />
      <div class="login-logo-text">
        <strong>ASN Pfeil Phönix</strong>
        <span>Umfrage-Auswertung 2026</span>
      </div>
    </div>
    <h1 class="login-title">Anmelden</h1>
    <p class="login-sub">Nur für autorisierte Administratoren.</p>
    <div class="field"><label>E-Mail</label><input type="email" id="login-email" /></div>
    <div class="field"><label>Passwort</label><input type="password" id="login-password" /></div>
    <button class="btn-login" id="btn-login">Einloggen</button>
    <div class="login-error" id="login-error"></div>
  </div>
</div>

<!-- Admin -->
<div id="admin-wrap" class="admin-wrap">
  <header class="header">
    <div class="header-brand">
      <img src="/images/asn-logo.svg" alt="" />
      <div class="header-brand-text">
        <strong>Mitgliederbefragung 2026</strong>
        <span>Ergebnisse & Auswertung</span>
      </div>
    </div>
    <div class="header-right">
      <a href="/verwaltung" class="btn-logout" style="text-decoration:none">← Übersicht</a>
      <span class="header-badge">Intern</span>
      <span class="header-user" id="header-user"></span>
      <button class="btn-logout" id="btn-logout">Ausloggen</button>
    </div>
  </header>

  <div class="admin-main" id="admin-content">
    <div class="loading"><div class="spinner"></div></div>
  </div>
</div>

<!-- Confirm modal -->
<div class="confirm-overlay" id="confirm-overlay">
  <div class="confirm-box">
    <h3 id="confirm-title">Löschen?</h3>
    <p id="confirm-msg">Diese Aktion kann nicht rückgängig gemacht werden.</p>
    <div class="confirm-btns">
      <button class="btn-cancel" onclick="closeConfirm()">Abbrechen</button>
      <button class="btn-confirm-del" id="btn-confirm-del">Löschen</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script is:inline set:html={`window.__SB_URL__=${JSON.stringify(SUPABASE_URL)};window.__SB_KEY__=${JSON.stringify(SUPABASE_ANON)};`}></script>

<script>
const SB_URL = window.__SB_URL__;
const SB_KEY = window.__SB_KEY__;
let accessToken = null;
let activeTab = 'stats';
let confirmAction = null;

// ── Shared admin session (single sign-on across all /verwaltung/* portals) ──
const SESSION_KEY = 'asn_admin_session';
function saveSession(data, email) {
  try {
    localStorage.setItem(SESSION_KEY, JSON.stringify({
      access_token: data.access_token,
      email,
      expires_at: Date.now() + ((data.expires_in || 3600) * 1000) - 60000,
    }));
  } catch {}
}
function getSavedSession() {
  try {
    const raw = localStorage.getItem(SESSION_KEY);
    if (!raw) return null;
    const s = JSON.parse(raw);
    if (!s.expires_at || s.expires_at < Date.now()) return null;
    return s;
  } catch { return null; }
}
function clearSavedSession() {
  try { localStorage.removeItem(SESSION_KEY); } catch {}
}

function toast(msg, type = '') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast visible${type ? ' toast--' + type : ''}`;
  setTimeout(() => t.classList.remove('visible'), 3000);
}

async function sbFetch(path, opts = {}) {
  return fetch(`${SB_URL}${path}`, {
    ...opts,
    headers: {
      'Content-Type': 'application/json',
      'apikey': SB_KEY,
      'Authorization': `Bearer ${accessToken || SB_KEY}`,
      ...(opts.headers || {}),
    },
  });
}

// ── Helpers ────────────────────────────────────────────────
function fmt(iso) {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('de-DE', {
    day: '2-digit', month: '2-digit', year: 'numeric',
    hour: '2-digit', minute: '2-digit', timeZone: 'Europe/Berlin',
  });
}

function mean(vals) {
  if (!vals.length) return null;
  return (vals.reduce((a, b) => a + b, 0) / vals.length).toFixed(2);
}

function dist(vals, max = 5) {
  const d = {};
  for (let i = 1; i <= max; i++) d[i] = 0;
  vals.forEach(v => { if (d[v] !== undefined) d[v]++; });
  return d;
}

function freqMap(vals) {
  const f = {};
  [].concat(...vals.filter(v => v)).forEach(v => { f[v] = (f[v] || 0) + 1; });
  return f;
}

// ── Label maps ─────────────────────────────────────────────
const LBL = {
  q1: { selbst: 'Für mich selbst', kind: 'Im Namen meines Kindes', beides: 'Für mich & mein Kind' },
  q2: { herren_fussball: 'Herrenfußball', jugend_fussball: 'Jugendfußball', tennis: 'Tennis', radsport: 'Radsport', kegeln: 'Kegeln', dart: 'Darts', passiv: 'Passivmitglied' },
  q3: { unter10: 'Unter 10', '10-13': '10–13', '14-17': '14–17', '18-25': '18–25', '26-35': '26–35', '36-45': '36–45', '46-60': '46–60', über60: 'Über 60' },
  q4: { vollmitglied: 'Vollmitglied', jugend: 'Jugendmitglied', familie: 'Familie', foerdermitglied: 'Fördermitglied', sonstiges: 'Sonstiges' },
  q5: { unter1: '< 1 Jahr', '1-3': '1–3 Jahre', '4-10': '4–10 Jahre', über10: '> 10 Jahre' },
  q6: { sport: 'Um Sport zu treiben', kind_sport: 'Kind soll Sport treiben', gemeinschaft: 'Gemeinschaft', eingeladen: 'Eingeladen', unterstuetzen: 'Verein unterstützen', sonstiges: 'Sonstiges' },
  q7: { spielen: 'Spielen & Wettkämpfe', zuschauen: 'Zuschauen', gemeinschaft: 'Gemeinschaft', einrichtungen: 'Einrichtungen', lokal: 'Teil von etwas Lokalem', kinder: 'Umgebung für Kinder', tradition: 'Geschichte & Tradition', sonstiges: 'Sonstiges' },
  q17: { ja_regelmaessig: 'Ja, regelmäßig', ja_gelegentlich: 'Ja, gelegentlich', nein_wuerde_gerne: 'Nein, aber würde gerne', nein_nicht_moeglich: 'Nein, nicht möglich' },
  q21: { '0': '0 Std.', '1-5': '1–5 Std.', '6-10': '6–10 Std.', '11-20': '11–20 Std.', über20: '> 20 Std.', aufgabe: 'Aufgabenabhängig' },
  q22: { klar_wissen: 'Klare Aufgaben & Termine', konkrete_aufgaben: 'Konkrete statt offener Aufgaben', team: 'Im Team', alltag: 'Passt in meinen Alltag', anerkennung: 'Anerkennung', kommunikation: 'Bessere Kommunikation', sonstiges: 'Sonstiges' },
  q24: { keine: 'Keine Erhöhung', bis10: 'Bis 10%', bis25: 'Bis 25%', über25: 'Mehr als 25%', unsicher: 'Unsicher' },
  q25: { umkleide: 'Umkleideräume', plaetze: 'Plätze', vereinsheim: 'Vereinsheim', jugend: 'Jugendentwicklung', ausruestung: 'Ausrüstung', digital: 'Digitale Tools', events: 'Veranstaltungen', gelaende: 'Gelände', sonstiges: 'Sonstiges' },
  q30: { infrastruktur: 'Infrastruktur', menschen: 'Menschen & Kommunikation', organisation: 'Organisation & Ehrenamt', administration: 'Administration', finanzen: 'Finanzen & Förderung', sport: 'Sport & Angebote', informiert: 'Nur informiert' },
};

// ── Render helpers ──────────────────────────────────────────
function scaleBlock(qnum, title, vals) {
  if (!vals.length) return `<div class="q-stat"><div class="q-num">${qnum}</div><div class="q-title">${title}</div><div class="q-empty">Keine Antworten.</div></div>`;
  const m = mean(vals);
  const d = dist(vals);
  const maxCount = Math.max(...Object.values(d), 1);
  return `<div class="q-stat">
    <div class="q-num">${qnum}</div>
    <div class="q-title">${title} <span class="q-n">(n=${vals.length})</span></div>
    <div class="scale-vis">
      <div class="scale-mean-box">
        <div class="scale-mean-num">${m}</div>
        <div class="scale-mean-lbl">Mittelwert</div>
      </div>
      <div class="scale-bars">
        ${[1,2,3,4,5].map(i => `
          <div class="sbar-row">
            <div class="sbar-label">${i}</div>
            <div class="sbar-track"><div class="sbar-fill" style="width:${Math.round(d[i]/maxCount*100)}%"></div></div>
            <div class="sbar-count">${d[i]}</div>
          </div>`).join('')}
      </div>
    </div>
  </div>`;
}

function freqBlock(qnum, title, vals, labelMap) {
  const f = freqMap(vals);
  const n = vals.filter(v => v && (Array.isArray(v) ? v.length : true)).length;
  const sorted = Object.entries(f).sort((a, b) => b[1] - a[1]);
  if (!sorted.length) return `<div class="q-stat"><div class="q-num">${qnum}</div><div class="q-title">${title}</div><div class="q-empty">Keine Antworten.</div></div>`;
  const maxVal = Math.max(...sorted.map(([, v]) => v), 1);
  return `<div class="q-stat">
    <div class="q-num">${qnum}</div>
    <div class="q-title">${title} <span class="q-n">(n=${n})</span></div>
    <div class="freq-list">
      ${sorted.map(([k, v]) => `
        <div class="fbar-row">
          <div class="fbar-label">${labelMap[k] || k}</div>
          <div class="fbar-track"><div class="fbar-fill" style="width:${Math.round(v/maxVal*100)}%"></div></div>
          <div class="fbar-count">${v}</div>
        </div>`).join('')}
    </div>
  </div>`;
}

function freitextBlock(qnum, title, vals) {
  const filled = vals.filter(v => v && v.trim());
  return `<div class="q-stat">
    <div class="q-num">${qnum}</div>
    <div class="q-title">${title} <span class="q-n">(${filled.length} Antworten)</span></div>
    ${filled.length
      ? `<div class="ftext-list">${filled.map(v => `<div class="ftext-item">${v.replace(/</g,'&lt;')}</div>`).join('')}</div>`
      : '<div class="q-empty">Keine Antworten.</div>'}
  </div>`;
}

function gridBlock(qnum, title, rows) {
  return `<div class="q-stat">
    <div class="q-num">${qnum}</div>
    <div class="q-title">${title}</div>
    <table class="grid-table">
      <thead><tr><th>Aspekt</th><th>1</th><th>2</th><th>3</th><th>4</th><th>5</th><th>Ø</th><th>n</th></tr></thead>
      <tbody>${rows.map(({ label, vals }) => {
        const d = dist(vals);
        const m = mean(vals);
        return `<tr>
          <td>${label}</td>
          ${[1,2,3,4,5].map(i => `<td>${d[i] || 0}</td>`).join('')}
          <td class="mean-cell">${m || '—'}</td>
          <td>${vals.length}</td>
        </tr>`;
      }).join('')}</tbody>
    </table>
  </div>`;
}

// ── Render dashboard ────────────────────────────────────────
function renderStats(rows) {
  const sub = rows.filter(r => r.status === 'submitted');
  const n = sub.length;
  const g  = f => sub.map(r => r[f]).filter(v => v != null);
  const gi = f => sub.map(r => r[f]).filter(v => v != null).map(Number);

  return `
    <div class="stats-bar">
      <div class="stat-card"><div class="stat-card__val">${rows.length}</div><div class="stat-card__label">Eingegangen</div></div>
      <div class="stat-card"><div class="stat-card__val">${sub.length}</div><div class="stat-card__label">Abgeschlossen</div></div>
      <div class="stat-card"><div class="stat-card__val">${rows.length - sub.length}</div><div class="stat-card__label">In Bearbeitung</div></div>
      <div class="stat-card"><div class="stat-card__val">${n ? Math.round(sub.filter(r => r.sprache === 'en').length / n * 100) : 0}%</div><div class="stat-card__label">Auf Englisch</div></div>
    </div>

    <div class="section-card">
      <div class="section-head"><div class="section-title">Abschnitt 1 — Über dich</div></div>
      <div class="section-body">
        ${freqBlock('F1','Für wen ausgefüllt?', g('q1_fuer_wen'), LBL.q1)}
        ${freqBlock('F2','Aktive Abteilung(en)', g('q2_abteilungen'), LBL.q2)}
        ${freqBlock('F3','Altersgruppe', g('q3_altersgruppe'), LBL.q3)}
        ${freqBlock('F4','Mitgliedschaft', g('q4_mitgliedschaft'), LBL.q4)}
        ${freqBlock('F5','Mitgliedsdauer', g('q5_dauer'), LBL.q5)}
      </div>
    </div>

    <div class="section-card">
      <div class="section-head"><div class="section-title">Abschnitt 2 — Was der Verein bedeutet</div></div>
      <div class="section-body">
        ${freqBlock('F6','Beitrittsgrund', g('q6_gruende'), LBL.q6)}
        ${freqBlock('F7','Was schätzt du heute? (Top 3)', g('q7_top3'), LBL.q7)}
        ${scaleBlock('F8','Verbundenheit mit dem Verein', gi('q8_verbundenheit'))}
        ${freitextBlock('F8a','Was würde mehr Verbundenheit schaffen?', g('q8a_freitext'))}
      </div>
    </div>

    <div class="section-card">
      <div class="section-head"><div class="section-title">Abschnitt 3 — Unsere Werte</div></div>
      <div class="section-body">
        ${gridBlock('F9–F12','Identitätsaussagen (1=trifft gar nicht zu, 5=trifft vollständig zu / sehr wichtig)', [
          { label: 'F9 Tradition & Fairness — Heute', vals: gi('q9_heute') },
          { label: 'F9 Tradition & Fairness — Zukunft', vals: gi('q9_zukunft') },
          { label: 'F10 Toleranz & Vielfalt — Heute', vals: gi('q10_heute') },
          { label: 'F10 Toleranz & Vielfalt — Zukunft', vals: gi('q10_zukunft') },
          { label: 'F11 Sportlicher Erfolg — Heute', vals: gi('q11_heute') },
          { label: 'F11 Sportlicher Erfolg — Zukunft', vals: gi('q11_zukunft') },
          { label: 'F12 Mut zur Veränderung — Heute', vals: gi('q12_heute') },
          { label: 'F12 Mut zur Veränderung — Zukunft', vals: gi('q12_zukunft') },
        ])}
        ${freitextBlock('F13','Wichtigster Wert in einem Sportverein', g('q13_freitext'))}
      </div>
    </div>

    <div class="section-card">
      <div class="section-head"><div class="section-title">Abschnitt 4 — Wie wir heute dastehen</div></div>
      <div class="section-body">
        ${gridBlock('F14','Zufriedenheit (1=sehr unzufrieden, 5=sehr zufrieden)', [
          { label: 'Umkleideräume & Toiletten', vals: gi('q14_umkleide') },
          { label: 'Die Plätze', vals: gi('q14_plaetze') },
          { label: 'Sonstige Einrichtungen', vals: gi('q14_einrichtungen') },
          { label: 'Sauberkeit & Pflege', vals: gi('q14_sauberkeit') },
          { label: 'Vereinskommunikation', vals: gi('q14_kommunikation') },
        ])}
        ${freitextBlock('F15','Was würde am meisten verbessert werden?', g('q15_freitext'))}
        ${freitextBlock('F16','Was sollte auf keinen Fall geändert werden?', g('q16_freitext'))}
      </div>
    </div>

    <div class="section-card">
      <div class="section-head"><div class="section-title">Abschnitt 5 — Ehrenamt</div></div>
      <div class="section-body">
        ${freqBlock('F17','Schon ehrenamtlich mitgeholfen?', g('q17_ehrenamt'), LBL.q17)}
        ${freitextBlock('F18','Wobei wurde geholfen?', g('q18_freitext'))}
        ${scaleBlock('F19','Interesse an Skillsbörse', gi('q19_skillsboerse'))}
        ${freitextBlock('F20','Welche Fähigkeiten könnten angeboten werden?', g('q20_freitext'))}
        ${freqBlock('F21','Stunden pro Jahr', g('q21_stunden'), LBL.q21)}
        ${freqBlock('F22','Was würde Mitmachen leichter machen?', g('q22_leichter'), LBL.q22)}
      </div>
    </div>

    <div class="section-card">
      <div class="section-head"><div class="section-title">Abschnitt 6 — Beiträge</div></div>
      <div class="section-body">
        ${scaleBlock('F23','Preis-Leistungs-Verhältnis', gi('q23_preis_leistung'))}
        ${freqBlock('F24','Akzeptable Beitragserhöhung', g('q24_erhoehung'), LBL.q24)}
        ${freqBlock('F25','Investitionsprioritäten (Top 3)', g('q25_top3'), LBL.q25)}
      </div>
    </div>

    <div class="section-card">
      <div class="section-head"><div class="section-title">Abschnitt 7 — Arbeitsgruppen</div></div>
      <div class="section-body">
        ${freqBlock('F26','Interesse an Arbeitsgruppen', g('q30_gruppen'), LBL.q30)}
        <div class="q-stat">
          <div class="q-num">F27</div>
          <div class="q-title">Kontaktangaben <span style="color:var(--red);font-size:.78rem;font-weight:400">(⚠ nicht anonym)</span></div>
          ${(() => { const c = sub.filter(r => r.q31_kontakt).map(r => r.q31_kontakt);
            return c.length ? `<div class="ftext-list">${c.map(v => `<div class="ftext-item">👤 ${v.replace(/</g,'&lt;')}</div>`).join('')}</div>` : '<div class="q-empty">Keine Kontaktangaben.</div>'; })()}
        </div>
      </div>
    </div>

    <div class="section-card">
      <div class="section-head"><div class="section-title">Abschnitt 8 — Die nächsten fünf Jahre</div></div>
      <div class="section-body">
        ${freitextBlock('F28','Größte Priorität für den Fünfjahresplan', g('q26_freitext'))}
        ${freitextBlock('F29','Wichtigste Identitätsaussage und warum', g('q27_freitext'))}
        ${freitextBlock('F30','Was für ein Verein soll ASN in 5 Jahren sein?', g('q28_freitext'))}
      </div>
    </div>`;
}

function renderResponses(rows) {
  if (!rows.length) return '<div class="loading">Noch keine Antworten.</div>';
  return `<div class="section-card">
    <div class="section-head"><div class="section-title">Alle Antworten (${rows.length})</div></div>
    <div style="overflow-x:auto">
      <table class="resp-table">
        <thead><tr><th>Code</th><th>Datum</th><th>Status</th><th>Sprache</th><th></th></tr></thead>
        <tbody>
          ${rows.map(r => `<tr>
            <td><span class="code-mono">${r.code}</span></td>
            <td style="color:var(--mid);font-size:.85rem">${fmt(r.eingegangen_am)}</td>
            <td><span class="badge ${r.status === 'submitted' ? 'badge--submitted' : 'badge--progress'}">${r.status === 'submitted' ? 'Abgeschlossen' : 'In Bearbeitung'}</span></td>
            <td style="color:var(--mid)">${r.sprache === 'en' ? '🇬🇧 EN' : '🇩🇪 DE'}</td>
            <td><button class="btn-del" onclick="deleteOne('${r.id}','${r.code}')">Löschen</button></td>
          </tr>`).join('')}
        </tbody>
      </table>
    </div>
  </div>`;
}

// ── Render full page ────────────────────────────────────────
function renderPage(rows) {
  window.__rows__ = rows;
  const sub = rows.filter(r => r.status === 'submitted').length;

  document.getElementById('admin-content').innerHTML = `
    <div class="toolbar">
      <button class="btn-tool btn-tool--primary" onclick="downloadCsv()">⬇ CSV exportieren</button>
      <button class="btn-tool btn-tool--danger" onclick="confirmDeleteAll()">🗑 Alle löschen</button>
      <button class="btn-tool" onclick="loadAndRender()">↻ Aktualisieren</button>
    </div>

    <div class="tabs">
      <button class="tab active" id="tab-stats" onclick="switchTab('stats')">📊 Auswertung (${sub} abgeschlossen)</button>
      <button class="tab" id="tab-resp" onclick="switchTab('resp')">📋 Einzelantworten (${rows.length})</button>
    </div>

    <div class="tab-panel active" id="panel-stats">
      ${renderStats(rows)}
    </div>
    <div class="tab-panel" id="panel-resp">
      ${renderResponses(rows)}
    </div>`;
}

window.switchTab = function(tab) {
  activeTab = tab;
  document.getElementById('tab-stats').classList.toggle('active', tab === 'stats');
  document.getElementById('tab-resp').classList.toggle('active', tab === 'resp');
  document.getElementById('panel-stats').classList.toggle('active', tab === 'stats');
  document.getElementById('panel-resp').classList.toggle('active', tab === 'resp');
};

// ── Load ────────────────────────────────────────────────────
window.loadAndRender = async function() {
  document.getElementById('admin-content').innerHTML = '<div class="loading"><div class="spinner"></div></div>';
  try {
    const res = await sbFetch('/rest/v1/umfrage_antworten?select=*&order=eingegangen_am.desc');
    if (!res.ok) throw new Error('Laden fehlgeschlagen');
    renderPage(await res.json());
  } catch (err) {
    document.getElementById('admin-content').innerHTML = `<div class="loading" style="color:var(--red)">Fehler: ${err.message}</div>`;
  }
};

// ── CSV ─────────────────────────────────────────────────────
window.downloadCsv = function() {
  const rows = window.__rows__ || [];
  if (!rows.length) { toast('Keine Daten', 'error'); return; }
  const cols = ['code','status','sprache','eingegangen_am','abgeschlossen_am',
    'q1_fuer_wen','q2_abteilungen','q3_altersgruppe','q4_mitgliedschaft','q4_sonstiges','q5_dauer',
    'q6_gruende','q6_sonstiges','q7_top3','q7_sonstiges','q8_verbundenheit','q8a_freitext',
    'q9_heute','q9_zukunft','q10_heute','q10_zukunft','q11_heute','q11_zukunft','q12_heute','q12_zukunft','q13_freitext',
    'q14_umkleide','q14_plaetze','q14_einrichtungen','q14_sauberkeit','q14_kommunikation',
    'q15_freitext','q16_freitext','q17_ehrenamt','q18_freitext','q19_skillsboerse',
    'q20_freitext','q21_stunden','q22_leichter','q22_sonstiges',
    'q23_preis_leistung','q24_erhoehung','q25_top3','q25_sonstiges',
    'q30_gruppen','q31_kontakt','q26_freitext','q27_freitext','q28_freitext'];
  const esc = v => { const s = Array.isArray(v) ? v.join(', ') : String(v ?? '');
    return s.includes(';') || s.includes('"') || s.includes('\n') ? `"${s.replace(/"/g,'""')}"` : s; };
  const csv = '\uFEFF' + cols.join(';') + '\n' + rows.map(r => cols.map(c => esc(r[c])).join(';')).join('\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv;charset=utf-8;' }));
  a.download = 'umfrage-2026.csv'; a.click();
  toast(`${rows.length} Antworten exportiert`, 'success');
};

// ── Delete ──────────────────────────────────────────────────
window.deleteOne = function(id, code) {
  document.getElementById('confirm-title').textContent = 'Antwort löschen?';
  document.getElementById('confirm-msg').textContent = `Antwort mit Code ${code} wird unwiderruflich gelöscht.`;
  confirmAction = async () => {
    const res = await sbFetch(`/rest/v1/umfrage_antworten?id=eq.${id}`, { method: 'DELETE' });
    if (!res.ok) throw new Error('Löschen fehlgeschlagen');
    toast('Antwort gelöscht', 'success');
    loadAndRender();
  };
  document.getElementById('confirm-overlay').classList.add('visible');
};

window.confirmDeleteAll = function() {
  const rows = window.__rows__ || [];
  document.getElementById('confirm-title').textContent = 'Alle Antworten löschen?';
  document.getElementById('confirm-msg').textContent = `Alle ${rows.length} Antworten werden unwiderruflich gelöscht. Diese Aktion kann nicht rückgängig gemacht werden.`;
  confirmAction = async () => {
    const res = await sbFetch('/rest/v1/umfrage_antworten?id=neq.00000000-0000-0000-0000-000000000000', { method: 'DELETE' });
    if (!res.ok) throw new Error('Löschen fehlgeschlagen');
    toast('Alle Antworten gelöscht', 'success');
    loadAndRender();
  };
  document.getElementById('confirm-overlay').classList.add('visible');
};

window.closeConfirm = function() {
  document.getElementById('confirm-overlay').classList.remove('visible');
  confirmAction = null;
};

document.getElementById('btn-confirm-del').addEventListener('click', async () => {
  if (!confirmAction) return;
  const btn = document.getElementById('btn-confirm-del');
  btn.textContent = 'Wird gelöscht…'; btn.disabled = true;
  try { await confirmAction(); } catch (err) { toast('Fehler: ' + err.message, 'error'); }
  finally { btn.textContent = 'Löschen'; btn.disabled = false; closeConfirm(); }
});

// ── Login ────────────────────────────────────────────────────
function onAuthenticated(email) {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('admin-wrap').classList.add('visible');
  document.getElementById('header-user').textContent = email;
  loadAndRender();
}

async function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  const password = document.getElementById('login-password').value;
  const errEl = document.getElementById('login-error');
  errEl.classList.remove('visible');
  document.getElementById('btn-login').disabled = true;
  document.getElementById('btn-login').textContent = '…';
  try {
    const res = await fetch(`${SB_URL}/auth/v1/token?grant_type=password`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'apikey': SB_KEY },
      body: JSON.stringify({ email, password }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error_description || 'Login fehlgeschlagen');
    accessToken = data.access_token;
    saveSession(data, email);
    onAuthenticated(email);
  } catch (err) {
    errEl.textContent = err.message; errEl.classList.add('visible');
  } finally {
    document.getElementById('btn-login').disabled = false;
    document.getElementById('btn-login').textContent = 'Einloggen';
  }
}
document.getElementById('btn-login').addEventListener('click', doLogin);
document.getElementById('login-password').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
document.getElementById('btn-logout').addEventListener('click', async () => {
  await fetch(`${SB_URL}/auth/v1/logout`, {
    method: 'POST', headers: { 'Content-Type': 'application/json', 'apikey': SB_KEY, 'Authorization': `Bearer ${accessToken}` }
  });
  accessToken = null;
  clearSavedSession();
  document.getElementById('admin-wrap').classList.remove('visible');
  document.getElementById('login-screen').style.display = '';
  toast('Ausgeloggt');
});

// ── Auto-restore session from another /verwaltung/* portal ──
(() => {
  const saved = getSavedSession();
  if (saved) {
    accessToken = saved.access_token;
    onAuthenticated(saved.email);
  }
})();
</script>
</body>
</html>
