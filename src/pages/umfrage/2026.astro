---
// src/pages/umfrage/2026.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout title="Mitgliederbefragung 2026" description="Anonyme Mitgliederbefragung des ASN Pfeil Phönix e.V. 2026">

  <section class="survey-hero">
    <div class="container">
      <p class="section-eyebrow">ASN Pfeil Phönix e.V.</p>
      <h1 id="hero-title">Mitgliederbefragung <em>2026</em></h1>
      <p class="hero-sub" id="hero-sub">Deine Meinung formt unseren Fünfjahresplan. Anonym · ca. 10–15 Minuten</p>
      <!-- Language switcher -->
      <div class="lang-switch">
        <button class="lang-btn active" id="btn-de" onclick="setLang('de')">🇩🇪 Deutsch</button>
        <button class="lang-btn" id="btn-en" onclick="setLang('en')">🇬🇧 English</button>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container survey-container">

      <!-- Resume code entry -->
      <div class="resume-box" id="resume-box">
        <div class="resume-inner">
          <span class="resume-label" id="lbl-resume-title">Umfrage fortsetzen?</span>
          <div class="resume-row">
            <input class="field-input resume-input" type="text" id="resume-code-input"
              placeholder="z.B. PX7K2M" maxlength="6" style="text-transform:uppercase;letter-spacing:.1em" />
            <button class="btn btn--ghost resume-btn" id="btn-resume" onclick="resumeSurvey()">
              <span id="lbl-resume-btn">Laden</span>
            </button>
          </div>
          <div class="resume-error" id="resume-error"></div>
        </div>
      </div>

      <!-- Progress bar -->
      <div class="progress-wrap" id="progress-wrap" style="display:none">
        <div class="progress-sections" id="progress-sections"></div>
        <div class="progress-bar-outer">
          <div class="progress-bar-inner" id="progress-bar"></div>
        </div>
        <div class="progress-label" id="progress-label"></div>
      </div>

      <!-- Survey panels -->
      <div id="survey-panels">

        <!-- ── SECTION 1 ── -->
        <div class="survey-panel" data-section="1">
          <div class="panel-head">
            <div class="panel-eyebrow" data-de="Abschnitt 1" data-en="Section 1"></div>
            <h2 class="panel-title" data-de="Über dich" data-en="About You"></h2>
          </div>

          <div class="q-block">
            <div class="q-label" data-de="F1. Für wen füllst du diese Umfrage aus?" data-en="Q1. Who are you completing this survey for?"></div>
            <div class="q-hint" data-de="Einfachauswahl" data-en="Single select"></div>
            <div class="radio-group" data-field="q1_fuer_wen">
              <label class="radio-opt"><input type="radio" name="q1" value="selbst" /><span data-de="Für mich selbst" data-en="For myself"></span></label>
              <label class="radio-opt"><input type="radio" name="q1" value="kind" /><span data-de="Im Namen meines Kindes" data-en="On behalf of my child"></span></label>
              <label class="radio-opt"><input type="radio" name="q1" value="beides" /><span data-de="Für mich und im Namen meines Kindes/meiner Kinder" data-en="For myself and on behalf of my child/children"></span></label>
            </div>
            <div class="q-note" data-de="Hinweis: Wenn du mehrere Kinder als Mitglieder hast, fülle bitte für jedes Kind eine separate Umfrage aus." data-en="Note: If you have more than one child who is a member, please complete a separate survey for each child."></div>
          </div>

          <div class="q-block">
            <div class="q-label" data-de="F2. In welcher/welchen Abteilung(en) bist du oder das Mitglied aktiv?" data-en="Q2. Which department(s) are you or the member you represent active in?"></div>
            <div class="q-hint" data-de="Mehrfachauswahl möglich" data-en="Select all that apply"></div>
            <div class="check-group" data-field="q2_abteilungen">
              <label class="check-opt"><input type="checkbox" value="herren_fussball" /><span data-de="Herrenfußball" data-en="Men's football"></span></label>
              <label class="check-opt"><input type="checkbox" value="jugend_fussball" /><span data-de="Jugendfußball" data-en="Youth football"></span></label>
              <div class="q-sub" id="q2-jugend-sub" style="display:none">
                <label class="field-label" data-de="Altersgruppe:" data-en="Age group:"></label>
                <input class="field-input" type="text" id="q2_jugend_ag" style="max-width:200px" placeholder="z.B. U12" />
              </div>
              <label class="check-opt"><input type="checkbox" value="tennis" /><span>Tennis</span></label>
              <label class="check-opt"><input type="checkbox" value="radsport" /><span data-de="Radsport" data-en="Cycling"></span></label>
              <label class="check-opt"><input type="checkbox" value="kegeln" /><span data-de="Kegeln" data-en="Bowling"></span></label>
              <label class="check-opt"><input type="checkbox" value="dart" /><span>Darts</span></label>
              <label class="check-opt"><input type="checkbox" value="passiv" /><span data-de="Nicht aktiv / Passivmitglied" data-en="Not active / social member"></span></label>
            </div>
          </div>

          <div class="q-block">
            <div class="q-label" data-de="F3. Welche Altersgruppe vertrittst du?" data-en="Q3. Which age group do you represent?"></div>
            <div class="q-hint" data-de="Einfachauswahl" data-en="Single select"></div>
            <div class="radio-group" data-field="q3_altersgruppe">
              <label class="radio-opt"><input type="radio" name="q3" value="unter10" /><span data-de="Unter 10" data-en="Under 10"></span></label>
              <label class="radio-opt"><input type="radio" name="q3" value="10-13" /><span>10–13</span></label>
              <label class="radio-opt"><input type="radio" name="q3" value="14-17" /><span>14–17</span></label>
              <label class="radio-opt"><input type="radio" name="q3" value="18-25" /><span>18–25</span></label>
              <label class="radio-opt"><input type="radio" name="q3" value="26-35" /><span>26–35</span></label>
              <label class="radio-opt"><input type="radio" name="q3" value="36-45" /><span>36–45</span></label>
              <label class="radio-opt"><input type="radio" name="q3" value="46-60" /><span>46–60</span></label>
              <label class="radio-opt"><input type="radio" name="q3" value="über60" /><span data-de="Über 60" data-en="Over 60"></span></label>
            </div>
          </div>

          <div class="q-block">
            <div class="q-label" data-de="F4. Welche Mitgliedschaft hast du / hat das Mitglied?" data-en="Q4. What type of membership do you / does the member hold?"></div>
            <div class="radio-group" data-field="q4_mitgliedschaft">
              <label class="radio-opt"><input type="radio" name="q4" value="vollmitglied" /><span data-de="Vollmitglied (Erwachsene)" data-en="Full adult member"></span></label>
              <label class="radio-opt"><input type="radio" name="q4" value="jugend" /><span data-de="Jugendmitglied" data-en="Youth member"></span></label>
              <label class="radio-opt"><input type="radio" name="q4" value="familie" /><span data-de="Familienmitgliedschaft" data-en="Family membership"></span></label>
              <label class="radio-opt"><input type="radio" name="q4" value="foerdermitglied" /><span data-de="Fördermitglied" data-en="Social / passive member"></span></label>
              <label class="radio-opt radio-opt--other"><input type="radio" name="q4" value="sonstiges" /><span data-de="Sonstiges:" data-en="Other:"></span>
                <input class="field-input other-input" type="text" id="q4_sonstiges" /></label>
            </div>
          </div>

          <div class="q-block">
            <div class="q-label" data-de="F5. Wie lange bist du / ist das Mitglied schon dabei?" data-en="Q5. How long have you / has the member been part of the club?"></div>
            <div class="radio-group" data-field="q5_dauer">
              <label class="radio-opt"><input type="radio" name="q5" value="unter1" /><span data-de="Weniger als 1 Jahr" data-en="Less than 1 year"></span></label>
              <label class="radio-opt"><input type="radio" name="q5" value="1-3" /><span data-de="1–3 Jahre" data-en="1–3 years"></span></label>
              <label class="radio-opt"><input type="radio" name="q5" value="4-10" /><span data-de="4–10 Jahre" data-en="4–10 years"></span></label>
              <label class="radio-opt"><input type="radio" name="q5" value="über10" /><span data-de="Mehr als 10 Jahre" data-en="More than 10 years"></span></label>
            </div>
          </div>
        </div>

        <!-- ── SECTION 2 ── -->
        <div class="survey-panel" data-section="2" style="display:none">
          <div class="panel-head">
            <div class="panel-eyebrow" data-de="Abschnitt 2" data-en="Section 2"></div>
            <h2 class="panel-title" data-de="Was der Verein dir bedeutet" data-en="What the Club Means to You"></h2>
          </div>

          <div class="q-block">
            <div class="q-label" data-de="F6. Warum bist du / ist das Mitglied ursprünglich dem Verein beigetreten?" data-en="Q6. Why did you / did the member originally join the club?"></div>
            <div class="q-hint" data-de="Mehrfachauswahl möglich" data-en="Select all that apply"></div>
            <div class="check-group" data-field="q6_gruende">
              <label class="check-opt"><input type="checkbox" value="sport" /><span data-de="Um Sport zu treiben" data-en="To play sport"></span></label>
              <label class="check-opt"><input type="checkbox" value="kind_sport" /><span data-de="Damit mein Kind Sport treiben kann" data-en="For my child to play sport"></span></label>
              <label class="check-opt"><input type="checkbox" value="gemeinschaft" /><span data-de="Wegen der Gemeinschaft" data-en="For the social community"></span></label>
              <label class="check-opt"><input type="checkbox" value="eingeladen" /><span data-de="Ich wurde von Freunden oder der Familie eingeladen" data-en="I was invited by a friend or family member"></span></label>
              <label class="check-opt"><input type="checkbox" value="unterstuetzen" /><span data-de="Um den Verein zu unterstützen" data-en="To support the club"></span></label>
              <label class="check-opt check-opt--other"><input type="checkbox" value="sonstiges" /><span data-de="Sonstiges:" data-en="Other:"></span>
                <input class="field-input other-input" type="text" id="q6_sonstiges" /></label>
            </div>
          </div>

          <div class="q-block">
            <div class="q-label" data-de="F7. Was schätzt du heute am meisten an der Mitgliedschaft? (Wähle deine Top 3)" data-en="Q7. What do you value most about being a member today? (Rank your top 3)"></div>
            <div class="q-hint" data-de="Wähle bis zu 3 Optionen" data-en="Select up to 3 options"></div>
            <div class="check-group check-group--max3" data-field="q7_top3" data-max="3">
              <label class="check-opt"><input type="checkbox" value="spielen" /><span data-de="Spielen und Wettkämpfe" data-en="Playing and competing"></span></label>
              <label class="check-opt"><input type="checkbox" value="zuschauen" /><span data-de="Spiele verfolgen und Teams anfeuern" data-en="Watching matches and supporting teams"></span></label>
              <label class="check-opt"><input type="checkbox" value="gemeinschaft" /><span data-de="Die Gemeinschaft und Freundschaften" data-en="The social community and friendships"></span></label>
              <label class="check-opt"><input type="checkbox" value="einrichtungen" /><span data-de="Die Einrichtungen und das Gelände" data-en="The facilities and grounds"></span></label>
              <label class="check-opt"><input type="checkbox" value="lokal" /><span data-de="Teil von etwas Lokalem zu sein" data-en="Being part of something local"></span></label>
              <label class="check-opt"><input type="checkbox" value="kinder" /><span data-de="Eine sichere, aktive Umgebung für Kinder" data-en="A safe, active environment for children"></span></label>
              <label class="check-opt"><input type="checkbox" value="tradition" /><span data-de="Die Geschichte und Tradition des Vereins" data-en="The club's history and tradition"></span></label>
              <label class="check-opt check-opt--other"><input type="checkbox" value="sonstiges" /><span data-de="Sonstiges:" data-en="Other:"></span>
                <input class="field-input other-input" type="text" id="q7_sonstiges" /></label>
            </div>
            <div class="q-counter" id="q7-counter"></div>
          </div>

          <div class="q-block">
            <div class="q-label" data-de="F8. Wie verbunden fühlst du dich mit dem Verein als Gemeinschaft?" data-en="Q8. How connected do you feel to the club as a community?"></div>
            <div class="scale-label" data-de="1 = Überhaupt nicht verbunden  —  5 = Sehr stark verbunden" data-en="1 = Not at all connected  —  5 = Very strongly connected"></div>
            <div class="scale-group" data-field="q8_verbundenheit">
              <label class="scale-opt"><input type="radio" name="q8" value="1" /><span>1</span></label>
              <label class="scale-opt"><input type="radio" name="q8" value="2" /><span>2</span></label>
              <label class="scale-opt"><input type="radio" name="q8" value="3" /><span>3</span></label>
              <label class="scale-opt"><input type="radio" name="q8" value="4" /><span>4</span></label>
              <label class="scale-opt"><input type="radio" name="q8" value="5" /><span>5</span></label>
            </div>
          </div>

          <div class="q-block">
            <div class="q-label" data-de="F8a. Gibt es etwas, das dir helfen würde, dich mehr mit dem Verein verbunden zu fühlen?" data-en="Q8a. Is there anything that would make you feel more connected to the club?"></div>
            <textarea class="field-input" id="q8a_freitext" rows="3" data-field="q8a_freitext"></textarea>
          </div>
        </div>

        <!-- ── SECTION 3 ── -->
        <div class="survey-panel" data-section="3" style="display:none">
          <div class="panel-head">
            <div class="panel-eyebrow" data-de="Abschnitt 3" data-en="Section 3"></div>
            <h2 class="panel-title" data-de="Unsere Werte" data-en="Our Values"></h2>
            <p class="panel-intro" data-de="Zu Beginn dieses Jahres entwickelten engagierte Vereinsmitglieder vier Aussagen zur Identität des Vereins. Bitte bewertet für jede Aussage: (a) wie gut sie unseren Verein heute beschreibt, und (b) wie wichtig sie euch für unsere Zukunft ist." data-en="Earlier this year, a group of engaged club members developed four statements describing the club's identity. For each statement, please rate: (a) how well it describes our club today, and (b) how important it is for our future."></p>
          </div>

          <div class="q-block q-block--values">
            <div class="values-statement" id="vs1">„Wir sind ein Verein mit Tradition, der bodenständig, aber trotzdem weltoffen ist. Bei uns stehen Fairness und menschliches Miteinander im Mittelpunkt. Wir gewinnen mit Fairness. Wir verlieren mit Anstand."</div>
            <div class="scale-pair">
              <div class="scale-row">
                <div class="scale-label-small" data-de="Wie gut beschreibt das unseren Verein heute? (1 = Überhaupt nicht — 5 = Vollständig)" data-en="How well does this describe our club today? (1 = Not at all — 5 = Completely)"></div>
                <div class="scale-group" data-field="q9_heute">
                  <label class="scale-opt"><input type="radio" name="q9h" value="1"/><span>1</span></label>
                  <label class="scale-opt"><input type="radio" name="q9h" value="2"/><span>2</span></label>
                  <label class="scale-opt"><input type="radio" name="q9h" value="3"/><span>3</span></label>
                  <label class="scale-opt"><input type="radio" name="q9h" value="4"/><span>4</span></label>
                  <label class="scale-opt"><input type="radio" name="q9h" value="5"/><span>5</span></label>
                </div>
              </div>
              <div class="scale-row">
                <div class="scale-label-small" data-de="Wie wichtig ist das für unsere Zukunft? (1 = Überhaupt nicht — 5 = Sehr wichtig)" data-en="How important is this for our future? (1 = Not at all — 5 = Very important)"></div>
                <div class="scale-group" data-field="q9_zukunft">
                  <label class="scale-opt"><input type="radio" name="q9z" value="1"/><span>1</span></label>
                  <label class="scale-opt"><input type="radio" name="q9z" value="2"/><span>2</span></label>
                  <label class="scale-opt"><input type="radio" name="q9z" value="3"/><span>3</span></label>
                  <label class="scale-opt"><input type="radio" name="q9z" value="4"/><span>4</span></label>
                  <label class="scale-opt"><input type="radio" name="q9z" value="5"/><span>5</span></label>
                </div>
              </div>
            </div>
          </div>

          <div class="q-block q-block--values">
            <div class="values-statement" id="vs2">„Wir sind ein Verein, der Toleranz lebt. Bei uns steht der Mensch im Mittelpunkt. Wir gewinnen mit Offenheit, Nähe und Vielfalt. Wir verlieren mit starren Strukturen und Stillstand."</div>
            <div class="scale-pair">
              <div class="scale-row">
                <div class="scale-label-small" data-de="Wie gut beschreibt das unseren Verein heute?" data-en="How well does this describe our club today?"></div>
                <div class="scale-group" data-field="q10_heute">
                  <label class="scale-opt"><input type="radio" name="q10h" value="1"/><span>1</span></label>
                  <label class="scale-opt"><input type="radio" name="q10h" value="2"/><span>2</span></label>
                  <label class="scale-opt"><input type="radio" name="q10h" value="3"/><span>3</span></label>
                  <label class="scale-opt"><input type="radio" name="q10h" value="4"/><span>4</span></label>
                  <label class="scale-opt"><input type="radio" name="q10h" value="5"/><span>5</span></label>
                </div>
              </div>
              <div class="scale-row">
                <div class="scale-label-small" data-de="Wie wichtig ist das für unsere Zukunft?" data-en="How important is this for our future?"></div>
                <div class="scale-group" data-field="q10_zukunft">
                  <label class="scale-opt"><input type="radio" name="q10z" value="1"/><span>1</span></label>
                  <label class="scale-opt"><input type="radio" name="q10z" value="2"/><span>2</span></label>
                  <label class="scale-opt"><input type="radio" name="q10z" value="3"/><span>3</span></label>
                  <label class="scale-opt"><input type="radio" name="q10z" value="4"/><span>4</span></label>
                  <label class="scale-opt"><input type="radio" name="q10z" value="5"/><span>5</span></label>
                </div>
              </div>
            </div>
          </div>

          <div class="q-block q-block--values">
            <div class="values-statement" id="vs3">„Wir sind ein Verein, der gewinnt. Bei uns steht das erfolgreiche, sportliche und gemeinschaftliche Miteinander im Vordergrund. Wir gewinnen mit sportlicher Reise, Ambition und Spaß."</div>
            <div class="scale-pair">
              <div class="scale-row">
                <div class="scale-label-small" data-de="Wie gut beschreibt das unseren Verein heute?" data-en="How well does this describe our club today?"></div>
                <div class="scale-group" data-field="q11_heute">
                  <label class="scale-opt"><input type="radio" name="q11h" value="1"/><span>1</span></label>
                  <label class="scale-opt"><input type="radio" name="q11h" value="2"/><span>2</span></label>
                  <label class="scale-opt"><input type="radio" name="q11h" value="3"/><span>3</span></label>
                  <label class="scale-opt"><input type="radio" name="q11h" value="4"/><span>4</span></label>
                  <label class="scale-opt"><input type="radio" name="q11h" value="5"/><span>5</span></label>
                </div>
              </div>
              <div class="scale-row">
                <div class="scale-label-small" data-de="Wie wichtig ist das für unsere Zukunft?" data-en="How important is this for our future?"></div>
                <div class="scale-group" data-field="q11_zukunft">
                  <label class="scale-opt"><input type="radio" name="q11z" value="1"/><span>1</span></label>
                  <label class="scale-opt"><input type="radio" name="q11z" value="2"/><span>2</span></label>
                  <label class="scale-opt"><input type="radio" name="q11z" value="3"/><span>3</span></label>
                  <label class="scale-opt"><input type="radio" name="q11z" value="4"/><span>4</span></label>
                  <label class="scale-opt"><input type="radio" name="q11z" value="5"/><span>5</span></label>
                </div>
              </div>
            </div>
          </div>

          <div class="q-block q-block--values">
            <div class="values-statement" id="vs4">„Wir sind ein Verein, der Mut zur Veränderung hat. Das zeigt sich durch einen innovativen Geist und mutige Veränderungen, die wir Hand in Hand angehen."</div>
            <div class="scale-pair">
              <div class="scale-row">
                <div class="scale-label-small" data-de="Wie gut beschreibt das unseren Verein heute?" data-en="How well does this describe our club today?"></div>
                <div class="scale-group" data-field="q12_heute">
                  <label class="scale-opt"><input type="radio" name="q12h" value="1"/><span>1</span></label>
                  <label class="scale-opt"><input type="radio" name="q12h" value="2"/><span>2</span></label>
                  <label class="scale-opt"><input type="radio" name="q12h" value="3"/><span>3</span></label>
                  <label class="scale-opt"><input type="radio" name="q12h" value="4"/><span>4</span></label>
                  <label class="scale-opt"><input type="radio" name="q12h" value="5"/><span>5</span></label>
                </div>
              </div>
              <div class="scale-row">
                <div class="scale-label-small" data-de="Wie wichtig ist das für unsere Zukunft?" data-en="How important is this for our future?"></div>
                <div class="scale-group" data-field="q12_zukunft">
                  <label class="scale-opt"><input type="radio" name="q12z" value="1"/><span>1</span></label>
                  <label class="scale-opt"><input type="radio" name="q12z" value="2"/><span>2</span></label>
                  <label class="scale-opt"><input type="radio" name="q12z" value="3"/><span>3</span></label>
                  <label class="scale-opt"><input type="radio" name="q12z" value="4"/><span>4</span></label>
                  <label class="scale-opt"><input type="radio" name="q12z" value="5"/><span>5</span></label>
                </div>
              </div>
            </div>
          </div>

          <div class="q-block">
            <div class="q-label" data-de="F13. In deinen eigenen Worten: Welcher Wert oder welche Eigenschaft ist dir in einem Sportverein am wichtigsten?" data-en="Q13. In your own words: what value or quality matters most to you in a sports club?"></div>
            <textarea class="field-input" id="q13_freitext" rows="3" data-field="q13_freitext"></textarea>
          </div>
        </div>

        <!-- ── SECTION 4 ── -->
        <div class="survey-panel" data-section="4" style="display:none">
          <div class="panel-head">
            <div class="panel-eyebrow" data-de="Abschnitt 4" data-en="Section 4"></div>
            <h2 class="panel-title" data-de="Wie wir heute dastehen" data-en="How We Are Doing Today"></h2>
          </div>

          <div class="q-block">
            <div class="q-label" data-de="F14. Wie zufrieden bist du mit den folgenden Aspekten des Vereins?" data-en="Q14. How satisfied are you with the following aspects of the club?"></div>
            <div class="scale-label" data-de="1 = Sehr unzufrieden  —  5 = Sehr zufrieden" data-en="1 = Very dissatisfied  —  5 = Very satisfied"></div>
            <div class="grid-scale">
              <div class="grid-scale-header">
                <div></div>
                <div>1</div><div>2</div><div>3</div><div>4</div><div>5</div>
              </div>
              <div class="grid-scale-row" data-field="q14_umkleide">
                <div class="grid-label" data-de="Umkleideräume und Toiletten" data-en="Changing rooms and toilets"></div>
                <label><input type="radio" name="q14a" value="1"/></label>
                <label><input type="radio" name="q14a" value="2"/></label>
