              <label class="radio-opt"><input type="radio" name="q21" value="6-10" /><span data-de="6–10 Stunden" data-en="6–10 hours"></span></label>
              <label class="radio-opt"><input type="radio" name="q21" value="11-20" /><span data-de="11–20 Stunden" data-en="11–20 hours"></span></label>
              <label class="radio-opt"><input type="radio" name="q21" value="über20" /><span data-de="Mehr als 20 Stunden" data-en="More than 20 hours"></span></label>
