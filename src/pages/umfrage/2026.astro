  .hero-sub { color: rgba(255,255,255,.65); font-size: 1rem; margin-top: .4rem; }

  .lang-switch { display: flex; gap: .5rem; margin-top: 1.25rem; }
  .lang-btn { background: rgba(255,255,255,.12); color: rgba(255,255,255,.7); border: 1px solid rgba(255,255,255,.2); border-radius: var(--radius); padding: .4em 1em; font-family: var(--fb); font-size: .85rem; cursor: pointer; transition: all .15s; }
  .lang-btn.active { background: var(--orange); color: var(--white); border-color: var(--orange); }
  .lang-btn:hover:not(.active) { background: rgba(255,255,255,.2); }

  .survey-container { max-width: 780px; }

  /* Resume box */
  .resume-box { background: var(--navy-tint); border: 1px solid var(--navy-pale); border-radius: var(--radius-lg); padding: 1rem 1.5rem; margin-bottom: 1.5rem; }
  .resume-inner { display: flex; flex-direction: column; gap: .5rem; }
  .resume-label { font-size: .82rem; font-weight: 600; color: var(--navy); }
  .resume-row { display: flex; gap: .5rem; }
  .resume-input { max-width: 160px; font-family: monospace; letter-spacing: .1em; }
  .resume-btn { white-space: nowrap; }
  .resume-error { font-size: .78rem; color: #dc2626; min-height: 1rem; }

  /* Progress */
  .progress-wrap { margin-bottom: 2rem; }
  .progress-sections { display: flex; gap: 4px; margin-bottom: .5rem; flex-wrap: wrap; }
  .progress-section-dot { height: 6px; border-radius: 3px; flex: 1; min-width: 20px; background: var(--border); transition: background .3s; }
  .progress-section-dot.done { background: var(--orange); }
  .progress-section-dot.active { background: var(--navy); }
  .progress-bar-outer { height: 4px; background: var(--border); border-radius: 2px; margin-bottom: .5rem; }
  .progress-bar-inner { height: 100%; background: var(--navy); border-radius: 2px; transition: width .4s ease; }
  .progress-label { font-size: .78rem; color: var(--muted); font-weight: 600; }

  /* Panel */
  .survey-panel { animation: fadeUp .3s ease both; }
  .panel-head { margin-bottom: 2rem; padding-bottom: 1.25rem; border-bottom: 3px solid var(--orange); }
  .panel-eyebrow { font-size: .67rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--orange); margin-bottom: .4rem; }
  .panel-title { font-family: var(--fd); font-size: clamp(1.6rem,3vw,2.2rem); color: var(--navy); }
  .panel-intro { color: var(--mid); font-size: .9rem; margin-top: .5rem; line-height: 1.6; }

  /* Questions */
  .q-block { margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
  .q-block:last-child { border-bottom: none; }
  .q-block--values { background: var(--navy-tint); border: 1px solid var(--navy-pale); border-radius: var(--radius-lg); padding: 1.25rem; margin-bottom: 1.25rem; }
  .q-label { font-weight: 600; color: var(--ink); margin-bottom: .5rem; line-height: 1.5; }
  .q-hint { font-size: .78rem; color: var(--muted); margin-bottom: .6rem; }
  .q-note { font-size: .78rem; color: var(--muted); margin-top: .5rem; font-style: italic; line-height: 1.5; }
  .q-sub { margin-left: 1.5rem; margin-top: .5rem; }
  .q-counter { font-size: .78rem; color: var(--muted); margin-top: .4rem; }

  /* Values statement */
  .values-statement { font-style: italic; color: var(--navy); font-size: .95rem; line-height: 1.6; margin-bottom: 1rem; border-left: 3px solid var(--orange); padding-left: .75rem; }
  .scale-pair { display: flex; flex-direction: column; gap: .75rem; }
  .scale-row { display: flex; flex-direction: column; gap: .4rem; }
  .scale-label-small { font-size: .82rem; color: var(--mid); font-weight: 600; }

  /* Radio / Checkbox */
  .radio-group { display: flex; flex-direction: column; gap: .4rem; }
  .radio-opt { display: flex; align-items: flex-start; gap: .6rem; cursor: pointer; font-size: .92rem; color: var(--ink); padding: .4rem 0; }
  .radio-opt input[type="radio"] { accent-color: var(--navy); width: 16px; height: 16px; flex-shrink: 0; margin-top: 2px; }
  .check-group { display: flex; flex-direction: column; gap: .4rem; }
  .check-opt { display: flex; align-items: flex-start; gap: .6rem; cursor: pointer; font-size: .92rem; color: var(--ink); padding: .4rem 0; }
  .check-opt input[type="checkbox"] { accent-color: var(--navy); width: 16px; height: 16px; flex-shrink: 0; margin-top: 2px; }
  .check-opt--other, .radio-opt--other { flex-wrap: wrap; align-items: center; gap: .4rem; }
  .other-input { max-width: 300px; font-size: .88rem; padding: .35rem .6rem; }
  .check-opt.disabled { opacity: .45; pointer-events: none; }

  /* Scale */
  .scale-label { font-size: .8rem; color: var(--muted); margin-bottom: .6rem; }
  .scale-group { display: flex; gap: .5rem; flex-wrap: wrap; }
  .scale-opt { display: flex; flex-direction: column; align-items: center; gap: .3rem; cursor: pointer; }
  .scale-opt input[type="radio"] { accent-color: var(--navy); width: 20px; height: 20px; }
  .scale-opt span { font-size: .82rem; color: var(--mid); font-weight: 600; }

  /* Grid scale */
  .grid-scale { margin-top: .75rem; }
  .grid-scale-header { display: grid; grid-template-columns: 1fr repeat(5, 40px); gap: .25rem; font-size: .78rem; font-weight: 700; color: var(--muted); text-align: center; margin-bottom: .25rem; }
  .grid-scale-row { display: grid; grid-template-columns: 1fr repeat(5, 40px); gap: .25rem; align-items: center; padding: .5rem 0; border-bottom: 1px solid var(--border); }
  .grid-scale-row label { display: flex; justify-content: center; }
  .grid-scale-row input[type="radio"] { accent-color: var(--navy); width: 18px; height: 18px; }
  .grid-label { font-size: .88rem; color: var(--ink); line-height: 1.4; }

  /* Textarea */
  textarea.field-input { resize: vertical; }

  /* Nav */
  .survey-nav { display: flex; justify-content: space-between; align-items: center; margin-top: 2.5rem; gap: 1rem; flex-wrap: wrap; }
  .nav-left, .nav-right { display: flex; gap: .75rem; align-items: center; }
  .btn--save { font-size: .82rem; border-color: var(--border); color: var(--mid); }
  .btn--submit { background: var(--orange); color: var(--white); border-color: var(--orange); }
  .btn--submit:hover { background: #c96508; }
  .spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,.3); border-top-color: white; border-radius: 50%; animation: spin .7s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Code modal */
  .code-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 200; display: none; align-items: center; justify-content: center; padding: 1rem; }
  .code-modal-overlay.visible { display: flex; }
  .code-modal { background: var(--white); border-radius: var(--radius-lg); padding: 2.5rem 2rem; max-width: 420px; width: 100%; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,.3); }
  .code-modal-icon { font-size: 3rem; margin-bottom: 1rem; }
  .code-modal h3 { font-family: var(--fd); font-size: 1.6rem; color: var(--navy); margin-bottom: .5rem; }
  .code-modal p { color: var(--mid); font-size: .9rem; margin-bottom: 1rem; }
  .code-display { background: var(--navy); color: var(--orange); font-family: var(--fd); font-size: 2.5rem; letter-spacing: .2em; padding: .75rem 1.5rem; border-radius: var(--radius); margin: 1rem 0; }
  .code-note { font-size: .8rem; color: var(--muted); margin-bottom: 1.5rem; }

  /* Success */
  .success-screen { text-align: center; padding: 3rem 1rem; }
  .success-icon { font-size: 4rem; margin-bottom: 1rem; }
  .success-screen h2 { font-family: var(--fd); font-size: 2.5rem; color: var(--navy); margin-bottom: .75rem; }
  .success-screen p { color: var(--mid); max-width: 50ch; margin: 0 auto; line-height: 1.6; }

  /* Notice */
  .notice { display: flex; align-items: flex-start; gap: .7rem; border-radius: var(--radius); padding: .85rem 1rem; font-size: .85rem; line-height: 1.55; }
  .notice--warn { background: #fffbeb; color: #92400e; border: 1px solid #fde68a; }
  .notice__icon { font-size: 1rem; flex-shrink: 0; margin-top: .05rem; }

  /* Field */
  .field-input { border: 2px solid var(--border); border-radius: var(--radius); padding: .6rem .85rem; font-family: var(--fb); font-size: .95rem; color: var(--ink); background: var(--white); transition: border-color .15s; width: 100%; }
  .field-input:focus { outline: none; border-color: var(--navy); box-shadow: 0 0 0 3px rgba(15,41,114,.1); }
  .field-label { font-size: .8rem; font-weight: 600; color: var(--mid); }

  @media (max-width: 600px) {
    .grid-scale-header, .grid-scale-row { grid-template-columns: 1fr repeat(5, 32px); }
    .survey-nav { flex-direction: column-reverse; }
    .nav-left, .nav-right { width: 100%; justify-content: space-between; }
  }
</style>

<script>
(() => {
  'use strict';

  const TOTAL_SECTIONS = 8;
  const SECTION_NAMES_DE = ['Über dich','Was der Verein bedeutet','Unsere Werte','Wie wir dastehen','Ehrenamt','Beiträge','Arbeitsgruppen','Nächste 5 Jahre'];
  const SECTION_NAMES_EN = ['About You','What the Club Means','Our Values','How We Are Doing','Volunteering','Fees','Working Groups','Next 5 Years'];

  let currentSection = 1;
  let resumeCode = null;
  let lang = 'de';

  // ── Language ────────────────────────────────────────────────
  window.setLang = function(l) {
    lang = l;
    document.getElementById('btn-de').classList.toggle('active', l === 'de');
    document.getElementById('btn-en').classList.toggle('active', l === 'en');
    // Update all bilingual elements
    document.querySelectorAll('[data-de]').forEach(el => {
      const txt = l === 'de' ? el.dataset.de : el.dataset.en;
      if (txt !== undefined) {
        if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
          if (el.dataset.placeholderDe) el.placeholder = l === 'de' ? el.dataset.placeholderDe : el.dataset.placeholderEn;
        } else {
          el.textContent = txt;
        }
      }
    });
    // Values statements — handled separately due to quote characters in text
    const VS = {
      vs1: {
        de: '„Wir sind ein Verein mit Tradition, der bodenständig, aber trotzdem weltoffen ist. Bei uns stehen Fairness und menschliches Miteinander im Mittelpunkt. Wir gewinnen mit Fairness. Wir verlieren mit Anstand."',
        en: '"We are a club with tradition — grounded, but open to the world. Fairness and human togetherness are at the centre of everything we do. We win with fairness. We lose with dignity."'
      },
      vs2: {
        de: '„Wir sind ein Verein, der Toleranz lebt. Bei uns steht der Mensch im Mittelpunkt. Wir gewinnen mit Offenheit, Nähe und Vielfalt. Wir verlieren mit starren Strukturen und Stillstand."',
        en: '"We are a club that lives tolerance. The person is at the centre. We win with openness, closeness and diversity. We lose with rigid structures and standing still."'
      },
      vs3: {
        de: '„Wir sind ein Verein, der gewinnt. Bei uns steht das erfolgreiche, sportliche und gemeinschaftliche Miteinander im Vordergrund. Wir gewinnen mit sportlicher Reise, Ambition und Spaß."',
        en: '"We are a club that wins — and winning means something to us. Sporting ambition, fun and shared positive experiences are at the heart of what we do."'
      },
      vs4: {
        de: '„Wir sind ein Verein, der Mut zur Veränderung hat. Das zeigt sich durch einen innovativen Geist und mutige Veränderungen, die wir Hand in Hand angehen."',
        en: '"We are a club with the courage to change — innovative, forward-looking, and willing to make bold decisions together."'
      },
    };
    Object.entries(VS).forEach(([id, texts]) => {
      const el = document.getElementById(id);
      if (el) el.textContent = texts[l] || texts.de;
    });
    updateProgress();
  };

  // ── Progress ─────────────────────────────────────────────────
  function updateProgress() {
    const dotsEl = document.getElementById('progress-sections');
    const barEl = document.getElementById('progress-bar');
    const labelEl = document.getElementById('progress-label');
    const names = lang === 'de' ? SECTION_NAMES_DE : SECTION_NAMES_EN;

    dotsEl.innerHTML = Array.from({length: TOTAL_SECTIONS}, (_, i) => {
      const cls = i + 1 < currentSection ? 'done' : i + 1 === currentSection ? 'active' : '';
      return `<div class="progress-section-dot ${cls}" title="${names[i]}"></div>`;
    }).join('');

    const pct = ((currentSection - 1) / TOTAL_SECTIONS * 100).toFixed(0);
    barEl.style.width = `${pct}%`;
    labelEl.textContent = lang === 'de'
      ? `Abschnitt ${currentSection} von ${TOTAL_SECTIONS}: ${names[currentSection-1]}`
      : `Section ${currentSection} of ${TOTAL_SECTIONS}: ${names[currentSection-1]}`;
  }

  // ── Navigation ────────────────────────────────────────────────
  function showSection(n) {
    document.querySelectorAll('.survey-panel').forEach(p => p.style.display = 'none');
    const panel = document.querySelector(`.survey-panel[data-section="${n}"]`);
    if (panel) { panel.style.display = ''; window.scrollTo({top: 0, behavior: 'smooth'}); }
    currentSection = n;
    document.getElementById('btn-prev').style.display = n > 1 ? '' : 'none';
    document.getElementById('btn-next').style.display = n < TOTAL_SECTIONS ? '' : 'none';
    document.getElementById('btn-submit').style.display = n === TOTAL_SECTIONS ? '' : 'none';
    updateProgress();
  }

  document.getElementById('btn-next').addEventListener('click', () => {
    if (currentSection < TOTAL_SECTIONS) showSection(currentSection + 1);
  });
  document.getElementById('btn-prev').addEventListener('click', () => {
    if (currentSection > 1) showSection(currentSection - 1);
  });

  // ── Jugend sub-field ─────────────────────────────────────────
  document.querySelector('input[value="jugend_fussball"]')?.addEventListener('change', function() {
    document.getElementById('q2-jugend-sub').style.display = this.checked ? '' : 'none';
  });

  // ── Max-3 checkboxes ─────────────────────────────────────────
  document.querySelectorAll('.check-group--max3').forEach(group => {
    const max = parseInt(group.dataset.max || '3');
    const counterId = group.id?.replace('group','counter') ||
      (group.dataset.field === 'q7_top3' ? 'q7-counter' : group.dataset.field === 'q25_top3' ? 'q25-counter' : null);
    const updateCounter = () => {
      const checked = group.querySelectorAll('input[type="checkbox"]:checked').length;
      group.querySelectorAll('input[type="checkbox"]:not(:checked)').forEach(cb => {
        cb.closest('label').classList.toggle('disabled', checked >= max);
      });
      const el = counterId ? document.getElementById(counterId) : null;
      if (el) el.textContent = lang === 'de'
        ? `${checked} von ${max} ausgewählt`
        : `${checked} of ${max} selected`;
    };
    group.addEventListener('change', updateCounter);
  });

  // ── Collect answers ───────────────────────────────────────────
  function collectAnswers() {
    const answers: Record<string, any> = {};

    // Radio groups
    document.querySelectorAll('.radio-group[data-field]').forEach(group => {
      const field = (group as HTMLElement).dataset.field!;
      const checked = group.querySelector('input[type="radio"]:checked') as HTMLInputElement;
      if (checked) answers[field] = isNaN(Number(checked.value)) ? checked.value : Number(checked.value);
    });

    // Scale groups (also radio)
    document.querySelectorAll('.scale-group[data-field]').forEach(group => {
      const field = (group as HTMLElement).dataset.field!;
      const checked = group.querySelector('input[type="radio"]:checked') as HTMLInputElement;
      if (checked) answers[field] = Number(checked.value);
    });

    // Grid scale rows
    document.querySelectorAll('.grid-scale-row[data-field]').forEach(row => {
      const field = (row as HTMLElement).dataset.field!;
      const checked = row.querySelector('input[type="radio"]:checked') as HTMLInputElement;
      if (checked) answers[field] = Number(checked.value);
    });

    // Checkbox groups
    document.querySelectorAll('.check-group[data-field]').forEach(group => {
      const field = (group as HTMLElement).dataset.field!;
      const vals = Array.from(group.querySelectorAll('input[type="checkbox"]:checked'))
        .map(cb => (cb as HTMLInputElement).value);
      if (vals.length) answers[field] = vals;
    });

    // Textareas and text inputs with data-field
    document.querySelectorAll('[data-field]').forEach(el => {
      const field = (el as HTMLElement).dataset.field!;
      if (el.tagName === 'TEXTAREA' || el.tagName === 'INPUT') {
        const v = (el as HTMLInputElement).value.trim();
        if (v) answers[field] = v;
      }
    });

    // "Other" text inputs
    const otherFields: Record<string, string> = {
      'q4_sonstiges': 'q4_sonstiges',
      'q6_sonstiges': 'q6_sonstiges',
      'q7_sonstiges': 'q7_sonstiges',
      'q22_sonstiges': 'q22_sonstiges',
      'q25_sonstiges': 'q25_sonstiges',
      'q2_jugend_ag': 'q2_jugend_ag',
    };
    Object.entries(otherFields).forEach(([id, field]) => {
      const el = document.getElementById(id) as HTMLInputElement;
      if (el?.value.trim()) answers[field] = el.value.trim();
    });

    answers.sprache = lang;
    return answers;
  }

  // ── Resume ────────────────────────────────────────────────────
  window.resumeSurvey = async function() {
    const code = (document.getElementById('resume-code-input') as HTMLInputElement).value.trim().toUpperCase();
    const errEl = document.getElementById('resume-error');
    if (!code || code.length !== 6) {
      errEl.textContent = lang === 'de' ? 'Bitte 6-stelligen Code eingeben.' : 'Please enter a 6-character code.';
      return;
    }
    errEl.textContent = lang === 'de' ? 'Lädt...' : 'Loading...';
    try {
      const res = await fetch(`/api/save-umfrage?code=${code}`);
      const data = await res.json();
      if (!res.ok || !data.success) {
        errEl.textContent = data.error || (lang === 'de' ? 'Code nicht gefunden.' : 'Code not found.');
        return;
      }
      errEl.textContent = '';
      resumeCode = code;
      restoreAnswers(data.data);
      startSurvey();
      showSection(1); // Start from beginning with filled answers
    } catch {
      errEl.textContent = lang === 'de' ? 'Fehler beim Laden.' : 'Loading failed.';
    }
  };

  function restoreAnswers(data: Record<string, any>) {
    if (data.sprache) setLang(data.sprache);

    // Restore radio buttons
    Object.entries(data).forEach(([field, value]) => {
      if (value === null || value === undefined) return;
      // Radio groups
      const radioGroup = document.querySelector(`.radio-group[data-field="${field}"]`);
      if (radioGroup) {
        const rb = radioGroup.querySelector(`input[value="${value}"]`) as HTMLInputElement;
        if (rb) rb.checked = true;
      }
      // Scale groups
      const scaleGroup = document.querySelector(`.scale-group[data-field="${field}"]`);
      if (scaleGroup) {
        const rb = scaleGroup.querySelector(`input[value="${value}"]`) as HTMLInputElement;
        if (rb) rb.checked = true;
      }
      // Grid rows
      const gridRow = document.querySelector(`.grid-scale-row[data-field="${field}"]`);
      if (gridRow) {
        const rb = gridRow.querySelector(`input[value="${value}"]`) as HTMLInputElement;
        if (rb) rb.checked = true;
      }
      // Textareas
      const ta = document.querySelector(`[data-field="${field}"]`) as HTMLTextAreaElement;
      if (ta && ta.tagName === 'TEXTAREA') ta.value = value;
      // Checkboxes (arrays)
      if (Array.isArray(value)) {
        const checkGroup = document.querySelector(`.check-group[data-field="${field}"]`);
        if (checkGroup) {
          value.forEach(v => {
            const cb = checkGroup.querySelector(`input[value="${v}"]`) as HTMLInputElement;
            if (cb) cb.checked = true;
          });
        }
      }
    });
    // Restore other text fields
    ['q4_sonstiges','q6_sonstiges','q7_sonstiges','q22_sonstiges','q25_sonstiges','q2_jugend_ag'].forEach(id => {
      if (data[id]) {
        const el = document.getElementById(id) as HTMLInputElement;
        if (el) el.value = data[id];
      }
    });
    if (data.q2_jugend_ag) document.getElementById('q2-jugend-sub')!.style.display = '';
  }

  // ── Save ──────────────────────────────────────────────────────
  window.saveSurvey = async function() {
    const answers = collectAnswers();
    try {
      const res = await fetch('/api/save-umfrage', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code: resumeCode, answers, status: 'in_progress' }),
      });
      const data = await res.json();
      if (data.success) {
        resumeCode = data.code;
        document.getElementById('code-display')!.textContent = data.code;
        document.getElementById('code-overlay')!.classList.add('visible');
      }
    } catch { /* silent */ }
  };

  window.closeCodeModal = function() {
    document.getElementById('code-overlay')!.classList.remove('visible');
  };

  // ── Submit ────────────────────────────────────────────────────
  document.getElementById('btn-submit')!.addEventListener('click', async () => {
    const btn = document.getElementById('btn-submit')!;
    document.getElementById('submit-text')!.style.display = 'none';
    document.getElementById('submit-spinner')!.style.display = '';
    btn.setAttribute('disabled','true');
    try {
      const answers = collectAnswers();
      const res = await fetch('/api/save-umfrage', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code: resumeCode, answers, status: 'submitted' }),
      });
      const data = await res.json();
      if (data.success) {
        document.getElementById('survey-panels')!.style.display = 'none';
        document.getElementById('survey-nav')!.style.display = 'none';
        document.getElementById('progress-wrap')!.style.display = 'none';
        document.getElementById('success-screen')!.style.display = '';
        window.scrollTo({top: 0, behavior: 'smooth'});
      }
    } catch {
      document.getElementById('submit-text')!.style.display = '';
      document.getElementById('submit-spinner')!.style.display = 'none';
      btn.removeAttribute('disabled');
      alert(lang === 'de' ? 'Fehler beim Absenden. Bitte erneut versuchen.' : 'Submission failed. Please try again.');
    }
  });

  // ── Init — read URL params ─────────────────────────────────
  function startSurvey() {
    document.getElementById('resume-box')!.style.display = 'none';
    document.getElementById('progress-wrap')!.style.display = '';
    document.getElementById('survey-nav')!.style.display = '';
    showSection(1);
  }

  // Read lang and code from URL if coming from entry page
  const params = new URLSearchParams(window.location.search);
  const urlLang = params.get('lang');
  const urlCode = params.get('code');

  if (urlLang === 'en') setLang('en');
  else setLang('de');

  if (urlCode) {
    // Auto-resume if code passed from entry page
    (async () => {
      try {
        const res = await fetch(`/api/save-umfrage?code=${urlCode.toUpperCase()}`);
        const data = await res.json();
        if (data.success) {
          resumeCode = urlCode.toUpperCase();
          restoreAnswers(data.data);
        }
      } catch { /* ignore */ }
      startSurvey();
    })();
  } else {
    startSurvey();
  }
})();
</script>
