---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Papa from 'papaparse';
import fs from 'node:fs';
import path from 'node:path';

// ---- Load teams from CSV ----
const csvPath = path.join(process.cwd(), 'public/data/mannschaften.csv');
const csvText = fs.readFileSync(csvPath, 'utf-8').replace(/^\uFEFF/, ''); // strip BOM

const { data: allRows } = Papa.parse(csvText, {
  delimiter: ';',
  header: false,
  skipEmptyLines: false,
});

// Column indices (0-based):
// 0=Mannschaft, 1=Trainingszeiten, 2=Trainer1, 3=Tel1, 4=Mail1,
// 5=Trainer2, 6=Tel2, 7=Mail2, 8=Trainer3, 9=Tel3, 10=Mail3,
// 11=BFV, 12=Foto
const COLS = { name:0, tz:1, t1:2, p1:3, m1:4, t2:5, p2:6, m2:7, t3:8, p3:9, m3:10, bfv:11, foto:12 };

function cell(row: any[], idx: number) { return (row[idx] || '').toString().trim(); }

// Skip header row (row 0), group into sections
const sections: Record<string, any[]> = { Herren: [], Mädels: [], Jugend: [] };
let currentSection = 'Jugend';
const sectionHeaders = ['Herren', 'Mädels', 'Jugend'];

for (let i = 1; i < (allRows as any[]).length; i++) {
  const row = (allRows as any[])[i];
  const name = cell(row, COLS.name);
  if (!name) continue;
  if (sectionHeaders.includes(name)) { currentSection = name; continue; }
  sections[currentSection].push(row);
}

// News for this page
const posts = (await getCollection('news', ({ data }) => !data.draft && data.sport === 'fussball'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(d: Date) {
  return d.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

// Contacts
const contacts = [
  { rolle: 'Abteilungsleiter', name: '', foto: '', telefon: '', email: '' },
  { rolle: 'Großfeldkoordinator', name: '', foto: '', telefon: '', email: '' },
  { rolle: 'Kleinfeldkoordinator', name: '', foto: '', telefon: '', email: '' },
  { rolle: 'Sportliche Leitung', name: '', foto: '', telefon: '', email: '' },
];
---

<BaseLayout title="Fußball" description="Fußball bei ASN Pfeil Phönix — Herren, Mädels und Jugend in Nürnberg-Ziegelstein.">

  <!-- Header -->
  <header class="dept-header">
    <div class="container">
      <span class="section-eyebrow">Abteilung</span>
      <h1>Fußball</h1>
      <p class="dept-sub">Herren, Mädels &amp; Jugend — vereint unter einem Dach in Ziegelstein.</p>
    </div>
  </header>

  <!-- ===== MANNSCHAFTEN ===== -->
  <section class="section section--off">
    <div class="container">
      <p class="section-eyebrow">Unsere Teams</p>
      <h2>Mannschaften</h2>
      <p class="section-intro">Vom Bambini bis zur 1. Mannschaft — hier findest du alle Teams, Trainer und Spielpläne.</p>

      {Object.entries(sections).map(([gruppe, rows]) => rows.length > 0 && (
        <div class="team-group">
          <h3 class="team-group__title">{gruppe}</h3>
          <div class="team-grid">
            {rows.map((row: any) => {
              const name = cell(row, COLS.name);
              const t1 = cell(row, COLS.t1);
              const p1 = cell(row, COLS.p1);
              const m1 = cell(row, COLS.m1);
              const t2 = cell(row, COLS.t2);
              const p2 = cell(row, COLS.p2);
              const m2 = cell(row, COLS.m2);
              const t3 = cell(row, COLS.t3);
              const p3 = cell(row, COLS.p3);
              const m3 = cell(row, COLS.m3);
              const bfv = cell(row, COLS.bfv);
              const foto = cell(row, COLS.foto);
              return (
                <div class="team-card">
                  <div class="team-card__photo">
                    {foto
                      ? <img src={foto} alt={name} loading="lazy" />
                      : <div class="team-card__photo-ph">⚽</div>
                    }
                  </div>
                  <div class="team-card__body">
                    <h4 class="team-card__name">{name}</h4>
                    {t1 && (
                      <div class="team-card__trainers">
                        <div class="trainer">
                          <span class="trainer__name">⚽ {t1}</span>
                          {p1 && <a class="trainer__contact" href={`tel:${p1}`}>📞 {p1}</a>}
                          {m1 && <a class="trainer__contact" href={`mailto:${m1}`}>✉️ {m1}</a>}
                        </div>
                        {t2 && (
                          <div class="trainer">
                            <span class="trainer__name">⚽ {t2}</span>
                            {p2 && <a class="trainer__contact" href={`tel:${p2}`}>📞 {p2}</a>}
                            {m2 && <a class="trainer__contact" href={`mailto:${m2}`}>✉️ {m2}</a>}
                          </div>
                        )}
                        {t3 && (
                          <div class="trainer">
                            <span class="trainer__name">⚽ {t3}</span>
                            {p3 && <a class="trainer__contact" href={`tel:${p3}`}>📞 {p3}</a>}
                            {m3 && <a class="trainer__contact" href={`mailto:${m3}`}>✉️ {m3}</a>}
                          </div>
                        )}
                      </div>
                    )}
                    {bfv && (
                      <a href={bfv} class="team-card__bfv" target="_blank" rel="noopener">
                        BFV-Spielplan →
                      </a>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== CONTACTS ===== -->
  <section class="section">
    <div class="container">
      <p class="section-eyebrow">Ansprechpartner</p>
      <h2>Abteilungsleitung</h2>
      <div class="contacts-grid">
        {contacts.map(c => (
          <div class="contact-card">
            <div class="contact-card__photo">
              {c.foto
                ? <img src={c.foto} alt={c.name} />
                : <div class="contact-card__photo-ph">{c.rolle.charAt(0)}</div>
              }
            </div>
            <div class="contact-card__body">
              <span class="contact-card__rolle">{c.rolle}</span>
              <p class="contact-card__name">{c.name || 'Name folgt'}</p>
              {c.telefon && <a class="contact-card__link" href={`tel:${c.telefon}`}>📞 {c.telefon}</a>}
              {c.email && <a class="contact-card__link" href={`mailto:${c.email}`}>✉️ {c.email}</a>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== JUGENDPHILOSOPHIE ===== -->
  <section class="section section--off">
    <div class="container">
      <div class="philosophy-layout">
        <div class="philosophy-text">
          <p class="section-eyebrow">Unsere Philosophie</p>
          <h2>Jugendphilosophie</h2>
          <p>Unser Großfeldkoordinator erläutert unsere Jugendphilosophie und erklärt, wie sie sich von der anderer Vereine unterscheidet. Bei ASN Pfeil Phönix steht die Entwicklung des ganzen Menschen im Vordergrund — nicht nur der fußballerischen Fähigkeiten.</p>
          <p>Wir glauben daran, dass jedes Kind die Chance verdient, in einer unterstützenden Umgebung zu wachsen, Freude am Sport zu entwickeln und Teil einer echten Gemeinschaft zu sein.</p>
        </div>
        <div class="philosophy-video">
          <div class="video-wrapper">
            <iframe
              src="https://www.youtube.com/embed/Vd7fHZlPhUs"
              title="Jugendphilosophie ASN Pfeil Phönix"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MÄDCHENFUSSBALL ===== -->
  <section class="section">
    <div class="container">
      <div class="girls-layout">
        <div>
          <p class="section-eyebrow">Mädchenfußball</p>
          <h2>Fußball für Mädels</h2>
          <p class="girls-text">Unter der Leitung von Wolle Steitz verfolgt ASN Pfeil Phönix das klare Ziel, die erste Adresse für Mädchenfußball im Nürnberger Norden zu werden. Wolle und sein Team schaffen eine Umgebung, in der Mädchen nicht nur Fußball lernen, sondern Selbstvertrauen, Teamgeist und Freude am Sport entwickeln. Wer Lust hat mitzumachen — Mädels jeden Alters sind herzlich willkommen!</p>
          <a href="/verein#kontakt" class="btn btn--primary" style="margin-top:1.5rem">Kontakt aufnehmen →</a>
        </div>
        <div class="girls-stat-block">
          <div class="girls-stat">
            <span class="girls-stat__num">2</span>
            <span class="girls-stat__label">Mädchenteams</span>
          </div>
          <div class="girls-stat">
            <span class="girls-stat__num">U13</span>
            <span class="girls-stat__label">bis</span>
          </div>
          <div class="girls-stat">
            <span class="girls-stat__num">U17</span>
            <span class="girls-stat__label">Altersgruppen</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== NEWS ===== -->
  {posts.length > 0 && (
    <section class="section section--off">
      <div class="container">
        <p class="section-eyebrow">Aktuelles</p>
        <h2>Fußball-News</h2>
        <div class="grid-3">
          {posts.map(post => (
            <a href={`/news/${post.slug}`} class="card">
              {post.data.image && <img class="card__img" src={post.data.image} alt={post.data.title} loading="lazy" />}
              <div class="card__body">
                <div class="card__meta">
                  <span class="tag tag--fussball">Fußball</span>
                  <time>{formatDate(post.data.date)}</time>
                </div>
                <h3 class="card__title">{post.data.title}</h3>
                <p class="card__excerpt">{post.data.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style>
/* Header */
.dept-header { padding: 4rem 0 3rem; background: var(--navy-dark); border-bottom: 4px solid var(--navy-mid); }
.dept-header h1 { color: var(--white); font-size: clamp(2.5rem, 8vw, 6rem); }
.dept-header .section-eyebrow { color: rgba(255,255,255,.5); }
.dept-header .section-eyebrow::before { background: var(--orange); }
.dept-sub { color: rgba(255,255,255,.55); margin-top: .75rem; font-size: 1rem; }
.section-intro { color: var(--mid); margin-bottom: 2.5rem; max-width: 60ch; }

/* Team groups */
.team-group { margin-bottom: 3rem; }
.team-group__title {
  font-family: var(--fd); font-size: 1.6rem;
  color: var(--navy); margin-bottom: 1.25rem;
  padding-bottom: .5rem; border-bottom: 2px solid var(--navy-pale);
}

/* Team grid */
.team-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.25rem;
}
.team-card {
  background: var(--white); border-radius: var(--radius-lg);
  border: 1px solid var(--border); overflow: hidden;
  transition: box-shadow .2s, transform .2s;
}
.team-card:hover { box-shadow: 0 8px 30px rgba(15,41,114,.1); transform: translateY(-2px); }
.team-card__photo { aspect-ratio: 16/7; overflow: hidden; background: var(--navy-pale); }
.team-card__photo img { width: 100%; height: 100%; object-fit: cover; }
.team-card__photo-ph {
  width: 100%; height: 100%; display: flex; align-items: center;
  justify-content: center; font-size: 2.5rem; opacity: .3;
}
.team-card__body { padding: 1.1rem 1.25rem 1.25rem; }
.team-card__name { font-family: var(--fd); font-size: 1.2rem; margin-bottom: .6rem; color: var(--navy); }
.team-card__trainers { display: flex; flex-direction: column; gap: .4rem; margin-bottom: .75rem; }
.trainer { display: flex; flex-direction: column; gap: .1rem; }
.trainer__name { font-size: .85rem; font-weight: 500; color: var(--ink); }
.trainer__contact { font-size: .78rem; color: var(--navy); }
.trainer__contact:hover { text-decoration: underline; }
.team-card__bfv {
  display: inline-block; margin-top: .5rem;
  font-size: .75rem; font-weight: 600; color: var(--navy);
}
.team-card__bfv:hover { text-decoration: underline; }

/* Contacts */
.contacts-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1.5rem; margin-top: 2rem;
}
.contact-card {
  background: var(--white); border-radius: var(--radius-lg);
  border: 1px solid var(--border); overflow: hidden;
  display: flex; flex-direction: column; align-items: center;
  padding: 2rem 1.5rem; text-align: center;
  transition: box-shadow .2s, transform .2s;
}
.contact-card:hover { box-shadow: 0 8px 30px rgba(15,41,114,.1); transform: translateY(-2px); }
.contact-card__photo { width: 90px; height: 90px; border-radius: 50%; overflow: hidden; margin-bottom: 1rem; }
.contact-card__photo img { width: 100%; height: 100%; object-fit: cover; }
.contact-card__photo-ph {
  width: 100%; height: 100%; background: var(--navy);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--fd); font-size: 2rem; color: var(--white);
}
.contact-card__rolle {
  font-size: .65rem; font-weight: 700; letter-spacing: .12em;
  text-transform: uppercase; color: var(--orange); display: block; margin-bottom: .4rem;
}
.contact-card__name { font-family: var(--fd); font-size: 1.1rem; color: var(--navy); margin-bottom: .5rem; }
.contact-card__link {
  display: block; font-size: .8rem; color: var(--mid);
  margin-top: .25rem; transition: color .15s;
}
.contact-card__link:hover { color: var(--navy); }

/* Philosophy */
.philosophy-layout {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 3rem; align-items: center;
}
@media (max-width: 800px) { .philosophy-layout { grid-template-columns: 1fr; } }
.philosophy-text p { color: var(--mid); line-height: 1.75; margin-top: 1rem; }
.video-wrapper {
  position: relative; aspect-ratio: 16/9;
  border-radius: var(--radius-lg); overflow: hidden;
  box-shadow: 0 12px 40px rgba(15,41,114,.15);
}
.video-wrapper iframe { position: absolute; inset: 0; width: 100%; height: 100%; }

/* Girls football */
.girls-layout {
  display: grid; grid-template-columns: 1fr auto;
  gap: 3rem; align-items: center;
}
@media (max-width: 700px) { .girls-layout { grid-template-columns: 1fr; } }
.girls-text { color: var(--mid); line-height: 1.75; margin-top: 1rem; max-width: 60ch; }
.girls-stat-block {
  display: flex; flex-direction: column; gap: 1.5rem;
  text-align: center; min-width: 120px;
}
.girls-stat__num {
  display: block; font-family: var(--fd); font-size: 2.5rem;
  color: var(--navy); line-height: 1;
}
.girls-stat__label {
  display: block; font-size: .68rem; letter-spacing: .1em;
  text-transform: uppercase; color: var(--muted); margin-top: .2rem;
}
</style>